-- Tests for Perihelion.Nebula — pure procedural nebula field.
-- Run from repo root:
--   ./run-tests.sh   (or run-tests.sh individual files by editing the glob)
mod TestPerihelionNebula do

  pfn fabs(x : Float) : Float do
    if x < 0.0 do 0.0 - x else x end
  end

  pfn approx(a : Float, b : Float) : Bool do
    fabs(a - b) < 0.001
  end

  -- A star with just enough fields filled in for Nebula's purposes (only
  -- x/y matter to it); the rest are placeholders.
  pfn mk_star(x : Float, y : Float) : Star do
    { x: x, y: y, radius: 10.0, capture_radius: 30.0, speed_mult: 1.0, orbits: Nil }
  end

  pfn grid_stars(gx : Float, gy : Float, acc : List(Star)) : List(Star) do
    if gx > 3000.0 do
      acc
    else
      if gy > 3000.0 do
        grid_stars(gx + 1000.0, 0.0 - 3000.0, acc)
      else
        grid_stars(gx, gy + 1000.0, Cons(mk_star(gx, gy), acc))
      end
    end
  end

  -- A dense 7x7 grid of anchor points (49 total) across a large area, so
  -- tests below have plenty of independent cloud_chance() rolls to draw on
  -- -- at cloud_chance() = 0.30, the odds of a fixed seed rolling zero
  -- clouds across all 49 is astronomically small (0.70^49), unlike a
  -- smaller spread where a ~2%+ miss-all chance could make a fixed-seed
  -- assertion genuinely flaky.
  pfn test_stars() : List(Star) do
    grid_stars(0.0 - 3000.0, 0.0 - 3000.0, Nil)
  end

  -- Walk a grid of sample points, failing fast if any density falls outside
  -- [0, 1] (with a tiny epsilon for float slop).
  pfn check_bounded_row(x : Float, x_max : Float, y : Float, stars : List(Star), seed : Float, step : Float) : Bool do
    if x > x_max do
      true
    else
      let d = Perihelion.Nebula.density(x, y, stars, seed)
      if d < 0.0 - 0.0001 || d > 1.0001 do
        false
      else
        check_bounded_row(x + step, x_max, y, stars, seed, step)
      end
    end
  end

  pfn check_bounded_rows(x0 : Float, x1 : Float, y : Float, y_max : Float, stars : List(Star), seed : Float, step : Float) : Bool do
    if y > y_max do
      true
    else
      if check_bounded_row(x0, x1, y, stars, seed, step) do
        check_bounded_rows(x0, x1, y + step, y_max, stars, seed, step)
      else
        false
      end
    end
  end

  describe "density" do
    test "is bounded in [0, 1] across a dense grid of sample points" do
      -- covers the anchor spread at a fine step, several seeds
      assert (check_bounded_rows(0.0 - 2000.0, 2000.0, 0.0 - 2000.0, 2000.0, test_stars(), 1.0, 100.0))
      assert (check_bounded_rows(0.0 - 2000.0, 2000.0, 0.0 - 2000.0, 2000.0, test_stars(), 42.0, 100.0))
    end

    test "is 0 far outside any cloud's reach" do
      -- radius_max() is 700, anchor_jitter() is 90 -- a point a full 100000
      -- units from every anchor star is unreachable by any cloud.
      assert (Perihelion.Nebula.density(100000.0, 100000.0, test_stars(), 1.0) == 0.0)
      assert (Perihelion.Nebula.density(0.0 - 100000.0, 0.0, test_stars(), 7.0) == 0.0)
    end

    test "is deterministic: the same (x, y, stars, seed) always gives the same value" do
      let a = Perihelion.Nebula.density(123.0, 456.0, test_stars(), 9.0)
      let b = Perihelion.Nebula.density(123.0, 456.0, test_stars(), 9.0)
      assert (a == b)
    end

    test "at a cloud's own center, density is at least that cloud's strength" do
      match Perihelion.Nebula.visible_clouds(test_stars(), 0.0, 4000.0, 2000.0, 3.0) do
        Nil -> assert false   -- 49 anchors at cloud_chance 0.30 should yield at least one
        Cons(c, _) ->
          let d = Perihelion.Nebula.density(c.x, c.y, test_stars(), 3.0)
          assert (d >= c.strength - 0.001)
          assert (d <= 1.0)
      end
    end
  end

  describe "in_nebula" do
    test "agrees with density vs. the threshold" do
      match Perihelion.Nebula.visible_clouds(test_stars(), 0.0, 4000.0, 2000.0, 11.0) do
        Nil -> assert false
        Cons(c, _) ->
          -- dead center of a cloud is always well above the threshold
          assert (Perihelion.Nebula.in_nebula(c.x, c.y, test_stars(), 11.0))
      end
      -- far away is always false
      assert (!Perihelion.Nebula.in_nebula(100000.0, 100000.0, test_stars(), 11.0))
    end
  end

  describe "visible_clouds" do
    test "varies with seed (per-run layout actually changes)" do
      let a = Perihelion.Nebula.visible_clouds(test_stars(), 0.0, 4000.0, 2000.0, 1.0)
      let b = Perihelion.Nebula.visible_clouds(test_stars(), 0.0, 4000.0, 2000.0, 2.0)
      -- Different seeds should not produce the identical cloud list over a
      -- region this large (same count AND same every field would be
      -- astronomically unlikely by chance).
      assert (List.length(a) != List.length(b) || !clouds_eq(a, b))
    end

    test "every spawned cloud overlaps the star it's anchored to" do
      -- anchor_jitter() is well under radius_min(), so a cloud's center is
      -- always within reach of its own anchor star, however small it rolls.
      assert (Perihelion.Nebula.anchor_jitter() < Perihelion.Nebula.radius_min())
      match Perihelion.Nebula.visible_clouds(test_stars(), 0.0, 4000.0, 2000.0, 5.0) do
        Nil -> assert false
        Cons(_, _) -> assert true
      end
    end

    test "excludes stars far outside the visible band" do
      let near = mk_star(0.0, 0.0)
      let far = mk_star(0.0, 100000.0)
      let clouds = Perihelion.Nebula.visible_clouds(Cons(near, Cons(far, Nil)), 0.0, 2000.0, 2000.0, 5.0)
      assert (all_near(clouds))
    end

    test "cloud_chance is tuned down to 0.30" do
      assert (approx(Perihelion.Nebula.cloud_chance(), 0.30))
    end

    -- Isolate a single star across many seeds: any hit (cloud_chance()
    -- roll succeeds) now always produces 2-3 lobes (make_lobes), so this
    -- just needs to find one hit among plenty of independent rolls.
    test "a triggered star cloud has more than one lobe" do
      assert (any_multi_lobe(mk_star(0.0, 0.0), 1.0, 200.0))
    end

    -- Free clouds don't depend on any star at all -- an empty star list
    -- fed to visible_clouds can only produce non-Nil via the free-cloud
    -- path, across a view_h wide enough to span several bands.
    test "free-floating clouds can appear with no stars at all" do
      assert (any_free_cloud(1.0, 20.0))
    end
  end

  pfn any_multi_lobe(star : Star, seed : Float, seed_max : Float) : Bool do
    if seed > seed_max do
      false
    else
      let clouds = Perihelion.Nebula.visible_clouds(Cons(star, Nil), 0.0 - 10000.0, 20000.0, 2000.0, seed)
      if List.length(clouds) >= 2 do
        true
      else
        any_multi_lobe(star, seed + 1.0, seed_max)
      end
    end
  end

  pfn any_free_cloud(seed : Float, seed_max : Float) : Bool do
    if seed > seed_max do
      false
    else
      match Perihelion.Nebula.visible_clouds(Nil, 0.0, 20000.0, 2000.0, seed) do
        Nil -> any_free_cloud(seed + 1.0, seed_max)
        Cons(_, _) -> true
      end
    end
  end

  pfn all_near(cs : List(Cloud)) : Bool do
    match cs do
      Nil -> true
      Cons(c, rest) ->
        if fabs(c.y) < 5000.0 do all_near(rest) else false end
    end
  end

  pfn cloud_eq(a : Cloud, b : Cloud) : Bool do
    approx(a.x, b.x) && approx(a.y, b.y) && approx(a.radius, b.radius) && approx(a.strength, b.strength)
  end

  pfn clouds_eq(a : List(Cloud), b : List(Cloud)) : Bool do
    match (a, b) do
      (Nil, Nil) -> true
      (Cons(ca, ra), Cons(cb, rb)) ->
        if cloud_eq(ca, cb) do clouds_eq(ra, rb) else false end
      _ -> false
    end
  end

end
