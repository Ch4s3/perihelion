-- Perihelion.Level — pure procedural star placement. Threads a Random.Rng
-- explicitly; a fixed seed reproduces an identical star ladder.
-- (Named Level, not Gen: stdlib already has a Gen module.) Uses stdlib
-- Random, whose sfc32 core is bit-identical across the interpreter, native,
-- and --target js backends, so a seeded ladder is the same on every backend.
mod Perihelion.Level do

  -- ── Placement constants ──────────────────────────────────────────────
  fn margin() : Float do 60.0 end
  fn gap_min() : Float do 160.0 end
  fn gap_max() : Float do 260.0 end
  fn radius_min() : Float do 6.0 end
  fn radius_max() : Float do 26.0 end
  -- Capture multipliers bumped alongside the smaller cores so the capture
  -- rings stay a playable size even though the visible star is a good bit
  -- smaller (the ring is what the player actually aims at).
  fn capture_mult_min() : Float do 2.8 end
  fn capture_mult_max() : Float do 5.2 end
  -- How much capture_mult's roll leans toward a value derived from the same
  -- draw that sized the star (vs. its own fully independent draw) -- see
  -- next_star. 0 would be fully independent (today's behavior); 1 would
  -- make ring size a deterministic function of star size. A low weight
  -- keeps it a loose, mostly-independent trend rather than a hard rule.
  fn size_capture_correlation() : Float do 0.35 end
  fn speed_mult_min() : Float do 0.7 end
  fn speed_mult_max() : Float do 1.6 end

  -- Max horizontal jump from the previous star, bounded independent of
  -- view_w -- on a wide full-screen viewport, spanning the whole width would
  -- flatten the ladder into shallow near-horizontal hops. Kept comparable to
  -- (but a bit under) the vertical gap so the path trends vertical while
  -- still leaving real horizontal choice.
  fn max_dx() : Float do 220.0 end

  -- ── Randomness ───────────────────────────────────────────────────────
  -- One uniform-[0,1) draw, threading the Rng. Adapts stdlib Random's
  -- (value, rng) return order to this module's (rng, value) threading order,
  -- so every call site reads `let (rng', t) = draw(rng)`.
  pfn draw(rng : Random.Rng) : (Random.Rng, Float) do
    let (t, rng2) = Random.next_float(rng)
    let out = (rng2, t)
    out
  end

  doc "Public uniform-[0,1) draw for other Perihelion modules: (rng) -> (rng', t in [0,1))."
  fn draw_pub(rng : Random.Rng) : (Random.Rng, Float) do
    draw(rng)
  end

  pfn lerp(lo : Float, hi : Float, t : Float) : Float do
    lo + t * (hi - lo)
  end

  -- Ring count from a uniform draw: ~55% single, ~30% two, ~15% three.
  pfn ring_count_from(t : Float) : Int do
    if t < 0.55 do 1 else if t < 0.85 do 2 else 3 end end
  end

  -- Concentric orbit rings for a star, ordered inner -> outer. The outer ring
  -- is the capture boundary (radius == capture_radius, speed == the star's
  -- rolled speed_mult); inner rings sit at fixed fractions of it and spin
  -- faster (tighter orbit -> quicker sweep = a risk/reward the player opts
  -- into with S). n is always 1..3 (see ring_count_from).
  pfn make_orbits(outer_r : Float, outer_sp : Float, n : Int) : List(Orbit) do
    match n do
      1 -> Cons({ radius: outer_r, speed_mult: outer_sp }, Nil)
      2 -> Cons({ radius: outer_r * 0.6, speed_mult: outer_sp * 1.5 },
             Cons({ radius: outer_r, speed_mult: outer_sp }, Nil))
      _ -> Cons({ radius: outer_r * 0.5,  speed_mult: outer_sp * 1.8 },
             Cons({ radius: outer_r * 0.75, speed_mult: outer_sp * 1.35 },
               Cons({ radius: outer_r, speed_mult: outer_sp }, Nil)))
    end
  end

  doc "Place the next star above `prev` (y-down world: smaller y), offset horizontally by at most max_dx() and clamped within margins of `view_w`. Radius, orbit-ring size, spin speed, and ring count all vary independently per star."
  fn next_star(rng : Random.Rng, prev : Star, view_w : Float) : (Star, Random.Rng) do
    let (r1, ty) = draw(rng)
    let (r2, tx) = draw(r1)
    let (r3, tr) = draw(r2)
    let (r4, tcm) = draw(r3)
    let (r5, tsm) = draw(r4)
    let (r6, trings) = draw(r5)
    let gap = lerp(gap_min(), gap_max(), ty)
    let dx = lerp(0.0 - max_dx(), max_dx(), tx)
    let x = Math.clamp_float(prev.x + dx, margin(), view_w - margin())
    -- Averaging tr with tr*tr softens the old pure-quadratic small-bias --
    -- still more small stars than large, but with real weight in the
    -- middle/large end too, instead of a narrow "mostly small" clump.
    let size_t = tr * tr * 0.5 + tr * 0.5
    let r = lerp(radius_min(), radius_max(), size_t)
    -- cm is mostly its own independent draw, but blended a little toward
    -- reusing tr (the same draw that sized the star) so bigger stars trend
    -- toward bigger capture rings on average -- a loose correlation, not a
    -- rule, since 65% of cm still comes from an unrelated draw (tcm).
    let cm_indep = lerp(capture_mult_min(), capture_mult_max(), tcm)
    let cm_from_size = lerp(capture_mult_min(), capture_mult_max(), tr)
    let cm = lerp(cm_indep, cm_from_size, size_capture_correlation())
    let sm = lerp(speed_mult_min(), speed_mult_max(), tsm)
    let cap = r * cm
    let orbits = make_orbits(cap, sm, ring_count_from(trings))
    let s = { x: x, y: prev.y - gap, radius: r, capture_radius: cap, speed_mult: sm, orbits: orbits }
    let result = (s, r6)
    result
  end

  doc "The opening board: a fixed centered first star plus two generated above it. Bottom-first order."
  fn initial_stars(rng : Random.Rng, view_w : Float) : (List(Star), Random.Rng) do
    let first = { x: view_w / 2.0, y: 520.0, radius: 18.0, capture_radius: 54.0, speed_mult: 1.0,
                  orbits: Cons({ radius: 54.0, speed_mult: 1.0 }, Nil) }
    let (s2, rng2) = next_star(rng, first, view_w)
    let (s3, rng3) = next_star(rng2, s2, view_w)
    let stars = Cons(first, Cons(s2, Cons(s3, Nil)))
    let result = (stars, rng3)
    result
  end

end
