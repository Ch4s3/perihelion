-- Perihelion — impure shell: input polling, Canvas rendering, the frame loop.
-- All game logic lives in Perihelion.Core (pure); star placement in Perihelion.Level.
-- The on_frame callback takes one ignored Int argument (`fn _ -> ...`) — see
-- stdlib/dom.march's module doc on deferred-callback signatures.
mod Perihelion do
  needs IO.Clock

  pfn two_pi() : Float do 6.283185307179586 end

  -- A fresh, unpredictable seed for a new universe at boot -- same idea as
  -- Tetris's lcg_seed, but simpler: Random.seed(n) accepts any Int magnitude
  -- (it only ever consumes n's low/high 32-bit words), so there's no need to
  -- clamp into a small positive range the way a hand-rolled LCG would.
  pfn boot_seed() : Int do
    float_to_int(unix_time(()) * 1000000.0)
  end

  -- ── Visual-effects state ─────────────────────────────────────────────
  -- Purely cosmetic, shell-local (not in the pure Game record, not tested):
  -- a short ball-position trail, an elapsed-time accumulator driving the
  -- stars' pulsating glow, live particle-burst instances, and an active
  -- capture-flash ring. Threaded through tick() the same way `game` is.
  type Particle = { x : Float, y : Float, vx : Float, vy : Float, life : Float, max_life : Float }

  -- actx/muted ride along in the same shell-local record: sound is another
  -- purely-cosmetic side effect keyed off the same before/after Game diff
  -- the particle/flash system already computes.
  type Fx = {
    trail : List((Float, Float)),
    t : Float,
    particles : List(Particle),
    flash : Option((Float, Float, Float)),
    actx : Audio.Ctx,
    muted : Bool
  }

  pfn fx_init() : Fx do
    { trail: Nil, t: 0.0, particles: Nil, flash: None, actx: Audio.create(), muted: false }
  end

  pfn trail_max() : Int do 22 end
  pfn flash_duration() : Float do 0.45 end
  pfn burst_count() : Int do 10 end
  pfn particle_life() : Float do 0.5 end

  -- Cheap deterministic hash (GLSL-style sin/frac trick), Float-keyed so it
  -- doubles as a per-star phase offset and a source of pseudo-random
  -- particle spread without threading the pure RNG through purely-visual code.
  pfn hashf(a : Float, b : Float) : Float do
    let x = Math.sin(a * 12.9898 + b * 78.233) * 43758.5453
    x - Math.floor(x)
  end

  pfn spawn_burst_particles(x : Float, y : Float, t : Float, i : Int, acc : List(Particle)) : List(Particle) do
    if i >= burst_count() do
      acc
    else
      let seed = t + int_to_float(i) * 7.0
      let a = hashf(seed, 1.0) * two_pi()
      let speed = 40.0 + hashf(seed, 2.0) * 90.0
      let life = particle_life() * (0.6 + 0.4 * hashf(seed, 3.0))
      let p = { x: x, y: y, vx: Math.cos(a) * speed, vy: Math.sin(a) * speed, life: life, max_life: life }
      spawn_burst_particles(x, y, t, i + 1, Cons(p, acc))
    end
  end

  pfn spawn_bursts(bursts : List((Float, Float)), t : Float, acc : List(Particle)) : List(Particle) do
    match bursts do
      Nil -> acc
      Cons(pt, rest) ->
        let (x, y) = pt
        spawn_bursts(rest, t, spawn_burst_particles(x, y, t, 0, acc))
    end
  end

  pfn step_particle(p : Particle, dt_s : Float) : Particle do
    { p with x: p.x + p.vx * dt_s, y: p.y + p.vy * dt_s, life: p.life - dt_s }
  end

  pfn step_particles(particles : List(Particle), dt_s : Float) : List(Particle) do
    List.filter(List.map(particles, fn p -> step_particle(p, dt_s)), fn p -> p.life > 0.0)
  end

  pfn push_trail(trail : List((Float, Float)), pos : (Float, Float)) : List((Float, Float)) do
    List.take(Cons(pos, trail), trail_max())
  end

  pfn step_flash(flash : Option((Float, Float, Float)), dt_s : Float) : Option((Float, Float, Float)) do
    match flash do
      None -> None
      Some(f) ->
        let (x, y, tr) = f
        let tr2 = tr - dt_s
        if tr2 > 0.0 do Some((x, y, tr2)) else None end
    end
  end

  pfn step_fx(fx : Fx, game : Game, dt_s : Float) : Fx do
    let t2 = fx.t + dt_s
    let trail2 = if was_playing(game) do push_trail(fx.trail, (game.ball_x, game.ball_y)) else fx.trail end
    let particles2 = step_particles(spawn_bursts(game.fx_bursts, t2, fx.particles), dt_s)
    let flash1 = step_flash(fx.flash, dt_s)
    let flash2 = match game.capture_flash do
      None -> flash1
      Some(pt) ->
        let (x, y) = pt
        Some((x, y, flash_duration()))
    end
    { fx with trail: trail2, t: t2, particles: particles2, flash: flash2 }
  end

  pfn draw_trail(ctx, trail : List((Float, Float)), i : Int, n : Int) : Unit do
    match trail do
      Nil -> ()
      Cons(pt, rest) ->
        let (x, y) = pt
        let f = 1.0 - int_to_float(i) / int_to_float(n)
        Canvas.set_global_alpha(ctx, f * 0.38)
        Canvas.set_fill_style(ctx, "#ffffff")
        Canvas.begin_path(ctx)
        Canvas.arc(ctx, x, y, 1.2 + 2.6 * f, 0.0, two_pi())
        Canvas.fill(ctx)
        draw_trail(ctx, rest, i + 1, n)
    end
  end

  pfn draw_particles(ctx, particles : List(Particle)) : Unit do
    match particles do
      Nil -> ()
      Cons(p, rest) ->
        let f = p.life / p.max_life
        Canvas.set_global_alpha(ctx, f)
        Canvas.set_fill_style(ctx, "#e8e8e8")
        Canvas.begin_path(ctx)
        Canvas.arc(ctx, p.x, p.y, 0.5 + 1.5 * f, 0.0, two_pi())
        Canvas.fill(ctx)
        draw_particles(ctx, rest)
    end
  end

  -- The captured star's ring flashes and briefly expands -- reads as a hit
  -- confirmation, same visual language as the Starfling reference.
  pfn draw_flash(ctx, flash : Option((Float, Float, Float))) : Unit do
    match flash do
      None -> ()
      Some(f) ->
        let (x, y, tr) = f
        let prog = 1.0 - tr / flash_duration()
        let r = 8.0 + prog * 60.0
        Canvas.set_global_alpha(ctx, (1.0 - prog) * 0.7)
        Canvas.set_stroke_style(ctx, "#ffffff")
        Canvas.set_line_width(ctx, 2.5 * (1.0 - prog) + 0.5)
        Canvas.begin_path(ctx)
        Canvas.arc(ctx, x, y, r, 0.0, two_pi())
        Canvas.stroke(ctx)
    end
  end

  -- Per-star pulse identity, all derived from the star's own (fixed) position
  -- so it's stable across frames with no extra state: whether it pulses at
  -- all (80% do), which of the three visual styles it uses, how fast it
  -- pulses, and its phase offset (so stars don't pulse in lockstep).
  pfn pulse_active(s : Star) : Bool do
    hashf(s.x, s.y) < 0.8
  end

  pfn pulse_style(s : Star) : Int do
    let r = hashf(s.x + 1.0, s.y + 1.0)
    if r < 0.34 do 0 else if r < 0.67 do 1 else 2 end end
  end

  pfn pulse_speed(s : Star) : Float do
    0.6 + hashf(s.x + 2.0, s.y + 2.0) * 1.8
  end

  pfn pulse_phase(s : Star) : Float do
    hashf(s.x + 3.0, s.y + 3.0) * two_pi()
  end

  -- Style-2 (orbiting dots) identity, per star: how many dots (2..5) and how
  -- fast they circle (0.4..2.8 rad/s) -- both derived from the star's fixed
  -- position, so no two look quite alike and none share the base pulse speed.
  pfn dot_count(s : Star) : Int do
    2 + float_to_int(hashf(s.x + 4.0, s.y + 4.0) * 4.0)
  end

  pfn dot_speed(s : Star) : Float do
    0.4 + hashf(s.x + 5.0, s.y + 5.0) * 2.4
  end

  -- Style 0: the ring itself brightens/thickens on the pulse, layered on
  -- top of the always-visible base ring drawn by draw_star.
  pfn draw_pulse_ring(ctx, s : Star, pulse : Float) : Unit do
    Canvas.set_global_alpha(ctx, 0.10 * pulse)
    Canvas.set_stroke_style(ctx, "#cfcfcf")
    Canvas.set_line_width(ctx, 1.0 + 0.6 * pulse)
    Canvas.begin_path(ctx)
    Canvas.arc(ctx, s.x, s.y, s.capture_radius, 0.0, two_pi())
    Canvas.stroke(ctx)
  end

  -- Style 1: a soft filled halo that breathes in and out.
  pfn draw_pulse_halo(ctx, s : Star, pulse : Float) : Unit do
    Canvas.set_global_alpha(ctx, 0.025 + 0.035 * pulse)
    Canvas.set_fill_style(ctx, "#ffffff")
    Canvas.begin_path(ctx)
    Canvas.arc(ctx, s.x, s.y, s.radius * (1.6 + 0.9 * pulse), 0.0, two_pi())
    Canvas.fill(ctx)
  end

  -- Style 2: `n` small points drifting around the star at dot_speed(s), evenly
  -- spaced (2*pi/n apart). n = dot_count(s); the caller seeds i = 0.
  pfn draw_pulse_particle(ctx, s : Star, t : Float, n : Int, i : Int) : Unit do
    if i >= n do
      ()
    else
      let a = t * dot_speed(s) + pulse_phase(s) + int_to_float(i) * (two_pi() / int_to_float(n))
      let r = s.radius * 1.8
      let px = s.x + Math.cos(a) * r
      let py = s.y + Math.sin(a) * r
      Canvas.set_global_alpha(ctx, 0.14)
      Canvas.set_fill_style(ctx, "#cfcfcf")
      Canvas.begin_path(ctx)
      Canvas.arc(ctx, px, py, 1.3, 0.0, two_pi())
      Canvas.fill(ctx)
      draw_pulse_particle(ctx, s, t, n, i + 1)
    end
  end

  -- Draw a star's orbit rings, inner -> outer. The last (outermost) ring is
  -- the capture boundary -- a gameplay-critical read, so it stays the most
  -- legible; inner rings (multi-orbit stars only) are fainter guides the
  -- player can drop to with S.
  pfn draw_orbit_rings(ctx, s : Star, orbits : List(Orbit)) : Unit do
    match orbits do
      Nil -> ()
      Cons(o, Nil) ->
        Canvas.set_global_alpha(ctx, 0.28)
        Canvas.set_stroke_style(ctx, "#9a9a9a")
        Canvas.set_line_width(ctx, 1.0)
        Canvas.begin_path(ctx)
        Canvas.arc(ctx, s.x, s.y, o.radius, 0.0, two_pi())
        Canvas.stroke(ctx)
      Cons(o, rest) ->
        Canvas.set_global_alpha(ctx, 0.16)
        Canvas.set_stroke_style(ctx, "#8a8a8a")
        Canvas.set_line_width(ctx, 1.0)
        Canvas.begin_path(ctx)
        Canvas.arc(ctx, s.x, s.y, o.radius, 0.0, two_pi())
        Canvas.stroke(ctx)
        draw_orbit_rings(ctx, s, rest)
    end
  end

  -- `aim` = Some((ball_x, ball_y, vx, vy)) while the ball is flying, None while
  -- orbiting. A star is "targeted" when the ball is moving toward it (velocity
  -- dotted with the ball->star vector is positive) and within a few capture
  -- radii -- i.e. a star you're approaching.
  pfn star_targeted(s : Star, aim : Option((Float, Float, Float, Float))) : Bool do
    match aim do
      None -> false
      Some(a) ->
        let (px, py, vx, vy) = a
        let dx = s.x - px
        let dy = s.y - py
        let range = s.capture_radius * 4.0
        vx * dx + vy * dy > 0.0 && dx * dx + dy * dy < range * range
    end
  end

  -- Bright, fast pulse on the capture ring -- a "this is your target" cue on
  -- the star(s) you're flying toward.
  pfn draw_target_pulse(ctx, s : Star, t : Float) : Unit do
    let pulse = 0.5 + 0.5 * Math.sin(t * 6.0)
    Canvas.set_global_alpha(ctx, 0.3 + 0.45 * pulse)
    Canvas.set_stroke_style(ctx, "#ffffff")
    Canvas.set_line_width(ctx, 1.2 + 1.6 * pulse)
    Canvas.begin_path(ctx)
    Canvas.arc(ctx, s.x, s.y, s.capture_radius, 0.0, two_pi())
    Canvas.stroke(ctx)
  end

  pfn draw_star(ctx, s : Star, t : Float, aim : Option((Float, Float, Float, Float))) : Unit do
    draw_orbit_rings(ctx, s, s.orbits)
    -- decorative pulse, layered on top of the base ring, on 80% of stars
    if pulse_active(s) do
      let pulse = 0.5 + 0.5 * Math.sin(t * pulse_speed(s) + pulse_phase(s))
      match pulse_style(s) do
        0 -> draw_pulse_ring(ctx, s, pulse)
        1 -> draw_pulse_halo(ctx, s, pulse)
        _ -> draw_pulse_particle(ctx, s, t, dot_count(s), 0)
      end
    else
      ()
    end
    -- gameplay cue: highlight a star the ball is approaching
    if star_targeted(s, aim) do draw_target_pulse(ctx, s, t) else () end
    -- star core
    Canvas.set_global_alpha(ctx, 1.0)
    Canvas.set_fill_style(ctx, "#f2f2f2")
    Canvas.begin_path(ctx)
    Canvas.arc(ctx, s.x, s.y, s.radius, 0.0, two_pi())
    Canvas.fill(ctx)
  end

  -- Single-pass "sin of a dot product" hash, same GLSL-style trick as
  -- asteroid_hash/Nebula.hash3. Before the sin/fract nonlinearity, its
  -- input is just a LINEAR combination of (gx, gy) -- so its level sets are
  -- near-parallel lines. Sampled sparsely (jittered nebula/asteroid
  -- anchors) that never shows, but tested on every cell of a dense grid
  -- (the starfield's existence/jitter/size tests) that linear structure
  -- bleeds through as visible diagonal star lines.
  pfn bg_hash_raw(a : Float, b : Float) : Float do
    let x = Math.sin(a * 12.9898 + b * 78.233) * 43758.5453
    x - Math.floor(x)
  end

  -- Two independently-parameterized raw hashes (rotated/scaled inputs, so
  -- their line artifacts run in different directions), summed and hashed
  -- again -- breaks up the single-pass banding above.
  pfn bg_hash(gx : Int, gy : Int, seed : Float) : Float do
    let fx = int_to_float(gx)
    let fy = int_to_float(gy)
    let h1 = bg_hash_raw(fx + seed * 37.719, fy - seed * 12.9898)
    let h2 = bg_hash_raw(fy * 3.271 - seed * 71.238, fx * 1.373 + seed * 5.113)
    bg_hash_raw(h1 * 269.5 + h2 * 183.3, fx * 0.618 + fy * 0.573 + seed)
  end

  -- Purely decorative, non-interactive background starfield: a deterministic
  -- hash keyed by world-space grid cell (not stored in Game) so it needs no
  -- spawn event and therefore never pops in -- whatever cell scrolls into
  -- view was already "there". Fills the full width (including the edges a
  -- wide viewport leaves empty around the narrow gameplay ladder) and
  -- scrolls vertically with the same camera translate as everything else.
  pfn bg_star_chance() : Float do 0.5 end
  -- Fraction of background stars (of those that spawn) that get a slow
  -- brightness pulse -- a small minority, so it reads as just a couple of
  -- twinkling points rather than the whole field animating.
  pfn bg_pulse_chance() : Float do 0.04 end

  pfn draw_bg_cell(ctx, gx : Int, gy : Int, cell : Float, seed : Float, t : Float) : Unit do
    let h = bg_hash(gx, gy, seed)
    if h > bg_star_chance() do
      ()
    else
      let jx = bg_hash(gx, gy + 1000, seed)
      let jy = bg_hash(gx + 1000, gy, seed)
      let x = int_to_float(gx) * cell + jx * cell
      let y = int_to_float(gy) * cell + jy * cell
      let br = 0.12 + 0.45 * bg_hash(gx + 2000, gy + 2000, seed)
      -- Square the size hash so it skews toward small with a real tail of
      -- notably bigger stars, instead of a narrow, samey-looking range.
      let st = bg_hash(gx - 2000, gy - 2000, seed)
      let sz = 1.0 + 1.8 * st * st
      let is_pulsing = bg_hash(gx + 3000, gy + 3000, seed) < bg_pulse_chance()
      let pulse = if is_pulsing do
          let speed = 0.35 + 0.45 * bg_hash(gx + 4000, gy, seed)
          let phase = bg_hash(gx, gy + 4000, seed) * two_pi()
          0.5 + 0.5 * Math.sin(t * speed + phase)
        else
          0.0
        end
      let br2 = if is_pulsing do br + (1.0 - br) * 0.6 * pulse else br end
      let sz2 = if is_pulsing do sz * (1.0 + 0.35 * pulse) else sz end
      Canvas.set_global_alpha(ctx, br2)
      Canvas.begin_path(ctx)
      Canvas.arc(ctx, x, y, sz2, 0.0, two_pi())
      Canvas.fill(ctx)
    end
  end

  pfn draw_bg_row(ctx, gx : Int, gx_max : Int, gy : Int, cell : Float, seed : Float, t : Float) : Unit do
    if gx > gx_max do
      ()
    else
      draw_bg_cell(ctx, gx, gy, cell, seed, t)
      draw_bg_row(ctx, gx + 1, gx_max, gy, cell, seed, t)
    end
  end

  pfn draw_bg_rows(ctx, gx0 : Int, gx1 : Int, gy : Int, gy_max : Int, cell : Float, seed : Float, t : Float) : Unit do
    if gy > gy_max do
      ()
    else
      draw_bg_row(ctx, gx0, gx1, gy, cell, seed, t)
      draw_bg_rows(ctx, gx0, gx1, gy + 1, gy_max, cell, seed, t)
    end
  end

  pfn draw_starfield(ctx, cam_x : Float, cam : Float, view_w : Float, view_h : Float, seed : Float, t : Float) : Unit do
    let cell = 70.0
    let gx0 = float_to_int(Math.floor(cam_x / cell)) - 1
    let gx1 = float_to_int(Math.floor((cam_x + view_w) / cell)) + 1
    let gy0 = float_to_int(Math.floor(cam / cell)) - 1
    let gy1 = float_to_int(Math.floor((cam + view_h) / cell)) + 1
    Canvas.set_fill_style(ctx, "#ffffff")
    draw_bg_rows(ctx, gx0, gx1, gy0, gy1, cell, seed, t)
    Canvas.set_global_alpha(ctx, 1.0)
  end

  -- ── Nebula ───────────────────────────────────────────────────────────
  -- Renders Perihelion.Nebula's clouds right after the starfield (behind
  -- stars/entities/ball, so the player passes THROUGH a cloud, not around
  -- it). "Subtle atmosphere": alpha is capped low enough that everything
  -- gameplay-relevant stays clearly readable through it.
  fn nebula_alpha_cap() : Float do 0.16 end

  pfn draw_nebula_clouds(ctx, clouds : List(Perihelion.Nebula.Cloud)) : Unit do
    match clouds do
      Nil -> ()
      Cons(c, rest) ->
        Canvas.fill_noise_circle(ctx, c.x, c.y, c.radius, nebula_alpha_cap() * c.strength)
        draw_nebula_clouds(ctx, rest)
    end
  end

  pfn draw_nebula(ctx, stars : List(Star), cam : Float, view_h : Float, seed : Float) : Unit do
    draw_nebula_clouds(ctx, Perihelion.Nebula.visible_clouds(stars, cam, view_h, seed))
  end

  pfn draw_stars(ctx, stars : List(Star), cam : Float, view_h : Float, t : Float, aim : Option((Float, Float, Float, Float))) : Unit do
    match stars do
      Nil -> ()
      Cons(s, rest) ->
        if s.y < cam + view_h + 100.0 && s.y > cam - 100.0 do
          draw_star(ctx, s, t, aim)
        else
          ()
        end
        draw_stars(ctx, rest, cam, view_h, t, aim)
    end
  end

  -- Cheap deterministic per-vertex hash (GLSL-style sin/frac trick) — no RNG
  -- state needed beyond the asteroid's own stored shape_seed.
  pfn asteroid_hash(seed : Float, i : Int) : Float do
    let x = Math.sin(seed * 12.9898 + int_to_float(i) * 78.233) * 43758.5453
    x - Math.floor(x)
  end

  pfn asteroid_vertex(a : Asteroid, i : Int) : (Float, Float) do
    let angle = int_to_float(i) * (two_pi() / 8.0)
    let jitter = 0.7 + 0.6 * asteroid_hash(a.shape_seed, i)
    let r = a.radius * jitter
    let pt = (a.x + Math.cos(angle) * r, a.y + Math.sin(angle) * r)
    pt
  end

  pfn draw_asteroid_edges(ctx, a : Asteroid, i : Int) : Unit do
    if i > 7 do
      Canvas.close_path(ctx)
      Canvas.fill(ctx)
    else
      let pt = asteroid_vertex(a, i)
      let (px, py) = pt
      match i do
        0 -> Canvas.move_to(ctx, px, py)
        _ -> Canvas.line_to(ctx, px, py)
      end
      draw_asteroid_edges(ctx, a, i + 1)
    end
  end

  pfn draw_asteroids(ctx, asteroids : List(Asteroid)) : Unit do
    match asteroids do
      Nil -> ()
      Cons(a, rest) ->
        let color = match a.mode do
          AsteroidDrifting -> "#8a8a94"
          AsteroidOrbiting(_, _) -> "#e8e8e8"
        end
        Canvas.set_fill_style(ctx, color)
        Canvas.begin_path(ctx)
        draw_asteroid_edges(ctx, a, 0)
        draw_asteroids(ctx, rest)
    end
  end

  pfn draw_shots(ctx, shots : List(Shot), color : String, r : Float) : Unit do
    match shots do
      Nil -> ()
      Cons(s, rest) ->
        Canvas.set_fill_style(ctx, color)
        Canvas.begin_path(ctx)
        Canvas.arc(ctx, s.x, s.y, r, 0.0, two_pi())
        Canvas.fill(ctx)
        draw_shots(ctx, rest, color, r)
    end
  end

  pfn ship_heading(sh : Ship) : Float do
    match sh.mode do
      ShipOrbiting(_, angle) ->
        let d = 0.0 - Perihelion.Core.orbit_dir(sh.star_idx)
        angle + d * 1.5707963
      ShipFlying(vx, vy) -> Math.atan2(vy, vx)
    end
  end

  pfn draw_ships(ctx, ships : List(Ship)) : Unit do
    match ships do
      Nil -> ()
      Cons(sh, rest) ->
        let pos = Perihelion.Combat.ship_pos(sh)
        let (sx, sy) = pos
        let heading = ship_heading(sh)
        Canvas.save(ctx)
        Canvas.translate(ctx, sx, sy)
        Canvas.rotate(ctx, heading)
        -- Bright near-white with a dark outline: at #a9a9a9 the ship was
        -- nearly indistinguishable from drifting asteroids (#8a8a94) and
        -- vanished into the greyscale clutter -- a threat needs contrast,
        -- not just a distinct (small, easy-to-miss) silhouette.
        Canvas.set_fill_style(ctx, "#e2e2e2")
        Canvas.set_stroke_style(ctx, "#333333")
        Canvas.set_line_width(ctx, 1.2)
        Canvas.begin_path(ctx)
        Canvas.move_to(ctx, 9.0, 0.0)
        Canvas.line_to(ctx, 0.0 - 6.0, 5.0)
        Canvas.line_to(ctx, 0.0 - 6.0, 0.0 - 5.0)
        Canvas.close_path(ctx)
        Canvas.fill(ctx)
        Canvas.stroke(ctx)
        Canvas.restore(ctx)
        draw_ships(ctx, rest)
    end
  end

  pfn draw_pickups(ctx, pickups : List(Pickup)) : Unit do
    match pickups do
      Nil -> ()
      Cons(pk, rest) ->
        Canvas.set_stroke_style(ctx, "#ffffff")
        Canvas.set_line_width(ctx, 2.0)
        Canvas.begin_path(ctx)
        Canvas.arc(ctx, pk.x, pk.y, 8.0, 0.0, two_pi())
        Canvas.stroke(ctx)
        draw_pickups(ctx, rest)
    end
  end

  pfn draw_runs(ctx, runs : List(RunRecord), view_w : Float, y : Float, i : Int) : Unit do
    if i >= 5 do
      ()
    else
      match runs do
        Nil -> ()
        Cons(r, rest) ->
          Canvas.set_font(ctx, "14px sans-serif")
          Canvas.fill_text(ctx,
            int_to_string(r.score) ++ " x" ++ int_to_string(r.max_mult)
              ++ " · " ++ int_to_string(r.stars) ++ " stars",
            view_w / 2.0, y)
          draw_runs(ctx, rest, view_w, y + 20.0, i + 1)
      end
    end
  end

  pfn draw_ball(ctx, game : Game) : Unit do
    Canvas.set_fill_style(ctx, "#ffffff")
    Canvas.begin_path(ctx)
    Canvas.arc(ctx, game.ball_x, game.ball_y, 6.0, 0.0, two_pi())
    Canvas.fill(ctx)
    if game.shield > 0 do
      Canvas.set_stroke_style(ctx, "#cccccc")
      Canvas.set_line_width(ctx, 2.0)
      Canvas.begin_path(ctx)
      Canvas.arc(ctx, game.ball_x, game.ball_y, 10.0, 0.0, two_pi())
      Canvas.stroke(ctx)
    else
      ()
    end
  end

  pfn upgrade_label(u : Perihelion.Upgrades.UpgradeKind) : String do
    match u do
      OffenseWeapon(Homing) -> "Homing Missiles"
      OffenseWeapon(Spread) -> "Spread Fire"
      OffenseWeapon(StarKiller) -> "Star Killer"
      OffenseWeapon(Base) -> "Base Weapon"
      OffenseFireRate -> "Faster Fire"
      DefenseBulletWard -> "Bullet Ward"
      DefenseDeflector -> "Deflector Plating"
      DefenseShield -> "Reinforced Shield"
      SpecialItem(StarThrust) -> "Star Thrust"
      SpecialItem(StarJump) -> "Star Jump"
      SpecialItem(TrajectoryPreview) -> "Trajectory Preview"
    end
  end

  -- Short (fits one line at 120px card width, 10px font), only shown on
  -- milestone/drop cards -- HUD's upgrade_label call sites don't want this.
  pfn upgrade_description(u : Perihelion.Upgrades.UpgradeKind) : String do
    match u do
      OffenseWeapon(Homing) -> "Curves toward threats"
      OffenseWeapon(Spread) -> "5-shot fan"
      OffenseWeapon(StarKiller) -> "Destroys a distant star"
      OffenseWeapon(Base) -> "Standard radial shot"
      OffenseFireRate -> "Faster shooting"
      DefenseBulletWard -> "Blocks one enemy shot"
      DefenseDeflector -> "Bounces asteroids"
      DefenseShield -> "Adds a shield charge"
      SpecialItem(StarThrust) -> "X: thrust to nearest star"
      SpecialItem(StarJump) -> "X: jump the ladder"
      SpecialItem(TrajectoryPreview) -> "Shows your flight path"
    end
  end

  pfn draw_milestone_card(ctx, u : Perihelion.Upgrades.UpgradeKind, cx : Float, view_h : Float) : Unit do
    Canvas.set_stroke_style(ctx, "#ffffff")
    Canvas.set_line_width(ctx, 2.0)
    Canvas.stroke_rect(ctx, cx - 60.0, view_h / 2.0 - 60.0, 120.0, 120.0)
    Canvas.set_text_align(ctx, "center")
    Canvas.set_font(ctx, "14px sans-serif")
    Canvas.fill_text(ctx, upgrade_label(u), cx, view_h / 2.0)
    Canvas.set_font(ctx, "10px sans-serif")
    Canvas.fill_text(ctx, upgrade_description(u), cx, view_h / 2.0 + 20.0)
  end

  pfn draw_milestone_cards(ctx, choices : List(Perihelion.Upgrades.UpgradeKind), view_w : Float, view_h : Float, i : Int) : Unit do
    match choices do
      Nil -> ()
      Cons(u, rest) ->
        let col_w = view_w / 3.0
        draw_milestone_card(ctx, u, col_w * (int_to_float(i) + 0.5), view_h)
        draw_milestone_cards(ctx, rest, view_w, view_h, i + 1)
    end
  end

  pfn draw_hud(ctx, game : Game) : Unit do
    Canvas.set_fill_style(ctx, "#eeeeee")
    Canvas.set_font(ctx, "18px sans-serif")
    Canvas.set_text_align(ctx, "left")
    Canvas.fill_text(ctx, int_to_string(game.score), 14.0, 28.0)
    Canvas.set_text_align(ctx, "right")
    Canvas.fill_text(ctx, "best " ++ int_to_string(game.best),
                     game.view_w - 14.0, 28.0)
    if game.multiplier > 1 do
      Canvas.set_text_align(ctx, "left")
      Canvas.fill_text(ctx, "x" ++ int_to_string(game.multiplier), 14.0, 52.0)
    else
      ()
    end
    Canvas.set_text_align(ctx, "left")
    Canvas.set_font(ctx, "13px sans-serif")
    Canvas.fill_text(ctx, upgrade_label(Perihelion.Upgrades.OffenseWeapon(Perihelion.Core.active_weapon(game))), 14.0, game.view_h - 60.0)
    match game.special do
      None -> ()
      Some(k) -> Canvas.fill_text(ctx, upgrade_label(Perihelion.Upgrades.SpecialItem(k)) ++ " x" ++ int_to_string(game.special_charges), 14.0, game.view_h - 40.0)
    end
    let defense_tags =
      (if game.bullet_ward do "ward " else "" end) ++
      (if game.deflector_plating do "deflect " else "" end) ++
      (if game.shield > 0 do "shield x" ++ int_to_string(game.shield) else "" end)
    Canvas.fill_text(ctx, defense_tags, 14.0, game.view_h - 20.0)
    Canvas.set_text_align(ctx, "center")
    match game.phase do
      Ready ->
        Canvas.set_font(ctx, "22px sans-serif")
        Canvas.fill_text(ctx, "tap to start",
                         game.view_w / 2.0, game.view_h / 2.0)
      Over ->
        Canvas.set_font(ctx, "22px sans-serif")
        Canvas.fill_text(ctx, "score " ++ int_to_string(game.score) ++ " — tap to retry",
                         game.view_w / 2.0, game.view_h / 2.0)
        draw_runs(ctx, game.runs, game.view_w, game.view_h / 2.0 + 36.0, 0)
      Playing -> ()
      Milestone ->
        Canvas.set_font(ctx, "20px sans-serif")
        Canvas.fill_text(ctx, "Choose an upgrade", game.view_w / 2.0, game.view_h / 2.0 - 90.0)
        draw_milestone_cards(ctx, game.milestone_choices, game.view_w, game.view_h, 0)
    end
  end

  pfn draw(ctx, game : Game, fx : Fx) : Unit do
    Canvas.set_global_alpha(ctx, 1.0)
    Canvas.set_fill_style(ctx, "#0a0a0a")
    Canvas.fill_rect(ctx, 0.0, 0.0, game.view_w, game.view_h)
    Canvas.save(ctx)
    Canvas.translate(ctx, 0.0 - game.camera_x, 0.0 - game.camera_y)
    let seedf = int_to_float(game.seed)
    draw_starfield(ctx, game.camera_x, game.camera_y, game.view_w, game.view_h, seedf, fx.t)
    draw_nebula(ctx, game.stars, game.camera_y, game.view_h, seedf)
    -- while flying, mark the stars the ball is heading toward (see star_targeted)
    let aim = match game.mode do
      Flying(vx, vy)     -> Some((game.ball_x, game.ball_y, vx, vy))
      Orbiting(_, _, _)  -> None
    end
    draw_stars(ctx, game.stars, game.camera_y, game.view_h, fx.t, aim)
    match Perihelion.Core.active_weapon(game) do
      StarKiller -> draw_starkiller_reticle(ctx, game)
      _ -> ()
    end
    match game.mode do
      Orbiting(idx, ring, angle) ->
        -- match, not `==`, on purpose: the JS backend compiles `Option(ADT)
        -- == Option(ADT)` to JS reference equality (===) instead of
        -- structural equality, so a freshly-constructed `Some(...)` never
        -- compares equal on the JS target even when contents match.
        match game.special do
          Some(TrajectoryPreview) ->
            draw_trajectory_preview(ctx, Perihelion.Core.predict_trajectory(game, idx, ring, angle))
          _ -> ()
        end
      Flying(_, _) -> () -- only meaningful while aiming, not mid-flight
    end
    draw_flash(ctx, fx.flash)
    draw_asteroids(ctx, game.asteroids)
    draw_ships(ctx, game.ships)
    draw_shots(ctx, game.player_shots, "#ffffff", 3.0)
    draw_shots(ctx, game.enemy_shots, "#8a8a94", 2.5)
    draw_pickups(ctx, game.pickups)
    draw_trail(ctx, fx.trail, 0, trail_max())
    draw_particles(ctx, fx.particles)
    Canvas.set_global_alpha(ctx, 1.0)
    draw_ball(ctx, game)
    Canvas.restore(ctx)
    draw_hud(ctx, game)
  end

  pfn draw_starkiller_reticle(ctx, game : Game) : Unit do
    match Perihelion.Core.star_at(game, Perihelion.Combat.starkiller_target_idx(game)) do
      None -> ()
      Some(s) ->
        Canvas.set_stroke_style(ctx, "#ff5555")
        Canvas.set_line_width(ctx, 2.0)
        Canvas.begin_path(ctx)
        Canvas.arc(ctx, s.x, s.y, s.capture_radius + 12.0, 0.0, two_pi())
        Canvas.stroke(ctx)
    end
  end

  pfn draw_trajectory_preview(ctx, points : List((Float, Float))) : Unit do
    Canvas.set_fill_style(ctx, "#888888")
    draw_trajectory_dots(ctx, points, 0)
  end

  -- Every 3rd predicted point, as a small dot -- reads as a dotted line
  -- without needing canvas dash-pattern support.
  pfn draw_trajectory_dots(ctx, points : List((Float, Float)), i : Int) : Unit do
    match points do
      Nil -> ()
      Cons(pt, rest) ->
        let (x, y) = pt
        if int_mod(i, 3) == 0 do
          Canvas.begin_path(ctx)
          Canvas.arc(ctx, x, y, 2.0, 0.0, two_pi())
          Canvas.fill(ctx)
        else
          ()
        end
        draw_trajectory_dots(ctx, rest, i + 1)
    end
  end

  pfn was_playing(g : Game) : Bool do
    match g.phase do
      Playing -> true
      _ -> false
    end
  end

  pfn is_over_phase(g : Game) : Bool do
    match g.phase do
      Over -> true
      _ -> false
    end
  end

  pfn resize_canvas(el, game : Game, w : Float, h : Float) : Unit do
    if w == game.view_w && h == game.view_h do
      ()
    else
      Dom.set_attr(el, "width", int_to_string(float_to_int(w)))
      Dom.set_attr(el, "height", int_to_string(float_to_int(h)))
    end
  end

  pfn is_ready_phase(p : Phase) : Bool do
    match p do
      Ready -> true
      _ -> false
    end
  end

  pfn is_milestone_phase(p : Phase) : Bool do
    match p do
      Milestone -> true
      _ -> false
    end
  end

  pfn is_orbiting_mode(m : BallMode) : Bool do
    match m do
      Orbiting(_, _, _) -> true
      _ -> false
    end
  end

  pfn is_flying_mode(m : BallMode) : Bool do
    match m do
      Flying(_, _) -> true
      _ -> false
    end
  end

  pfn toggle_mute(muted : Bool, keys : List(String)) : Bool do
    if List.any(keys, fn k -> k == "m" || k == "M") do !muted else muted end
  end

  -- Every trigger here reuses an event the Combat/Core layer already reports
  -- for the visual-effects system (fx_bursts, capture_flash, phase/mode
  -- transitions) -- no game logic exists solely to drive sound.
  pfn play_sfx(actx, muted : Bool, game : Game, g2 : Game) : Unit do
    if muted do
      ()
    else
      -- Ready -> Playing is always the result of the first real tap, so
      -- this is exactly where the required user gesture is available to
      -- unlock audio output.
      if is_ready_phase(game.phase) && was_playing(g2) do Audio.resume(actx) else () end
      if is_orbiting_mode(game.mode) && is_flying_mode(g2.mode) do
        Audio.beep(actx, 500.0, 0.04, "square")
      else
        ()
      end
      match g2.capture_flash do
        None -> ()
        Some(_) -> Audio.sweep(actx, 400.0, 900.0, 0.12, "sine")
      end
      if List.length(g2.player_shots) > List.length(game.player_shots) do
        Audio.beep(actx, 900.0, 0.05, "square")
      else
        ()
      end
      if List.length(g2.enemy_shots) > List.length(game.enemy_shots) do
        Audio.beep(actx, 500.0, 0.05, "sawtooth")
      else
        ()
      end
      if !List.is_empty(g2.fx_bursts) do
        Audio.noise_burst(actx, 0.2, 900.0)
      else
        ()
      end
      if List.length(g2.ships) < List.length(game.ships) do
        Audio.noise_burst(actx, 0.3, 400.0)
      else
        ()
      end
      if game.shield == 0 && g2.shield > 0 do
        Audio.beep(actx, 700.0, 0.06, "sine")
      else
        ()
      end
      if was_playing(game) && is_over_phase(g2) do
        Audio.sweep(actx, 300.0, 60.0, 0.5, "sawtooth")
      else
        ()
      end
    end
  end

  -- Maps a tap's x-position to the milestone card it landed on: 3 equal-width
  -- columns spanning the full viewport width.
  pfn milestone_tap_choice(taps : List((Int, Int)), view_w : Float, _view_h : Float) : Option(Int) do
    match taps do
      Nil -> None
      Cons(tap, _) ->
        let (tx, _) = tap
        let col_w = view_w / 3.0
        let idx = float_to_int(int_to_float(tx) / col_w)
        Some(if idx > 2 do 2 else idx end)
    end
  end

  pfn tick(ctx, el, game : Game, fx : Fx) : Unit do
    let taps = Dom.taps(el)
    let keys = Dom.key_presses()
    let cursor = Dom.pointer_pos(el)
    let (win_w, win_h) = Dom.window_size()
    let view_w = int_to_float(win_w)
    let view_h = int_to_float(win_h)
    resize_canvas(el, game, view_w, view_h)
    -- R hard-resets from ANY phase (see Core.update), but the Milestone
    -- branch below normally routes through pick_milestone instead of
    -- update -- which never looks at `keys` -- so without this check R
    -- would silently stop working while the milestone overlay is up.
    -- Reuse Core.wants_reset/update's own reset handling rather than
    -- reimplementing it here.
    let g2 = match game.phase do
      Milestone ->
        if Perihelion.Core.wants_reset(keys) do
          Perihelion.Core.update(game, taps, keys, cursor, view_w, view_h, Perihelion.Core.dt())
        else
          Perihelion.Core.pick_milestone(game, milestone_tap_choice(taps, view_w, view_h))
        end
      _ -> Perihelion.Core.update(game, taps, keys, cursor, view_w, view_h, Perihelion.Core.dt())
    end
    let muted2 = toggle_mute(fx.muted, keys)
    play_sfx(fx.actx, muted2, game, g2)
    let fx1 = step_fx(fx, g2, Perihelion.Core.dt())
    let fx2 = { fx1 with muted: muted2 }
    if was_playing(game) && is_over_phase(g2) do
      Dom.store_set("perihelion.v1", Perihelion.Core.encode_save(g2.best, g2.runs))
    else
      ()
    end
    draw(ctx, g2, fx2)
    Dom.on_frame(fn _ -> tick(ctx, el, g2, fx2))
  end

  -- Deferred to the first animation frame: at module-load time the browser
  -- hasn't computed layout yet, so window.innerWidth/innerHeight (and thus
  -- Dom.window_size()) read as 0 -- baking a 0x0 viewport into the initial
  -- star ladder. By the first on_frame callback, layout is guaranteed.
  pfn boot(ctx, node, best : Int, runs : List(RunRecord)) : Unit do
    let (win_w, win_h) = Dom.window_size()
    let view_w = int_to_float(win_w)
    let view_h = int_to_float(win_h)
    Dom.set_attr(node, "width", int_to_string(win_w))
    Dom.set_attr(node, "height", int_to_string(win_h))
    tick(ctx, node, Perihelion.Core.new_game_saved(boot_seed(), best, runs, view_w, view_h), fx_init())
  end

  fn main() : Unit do
    match Dom.find("game-canvas") do
      None -> println("no #game-canvas found")
      Some(node) ->
        match Canvas.get_context(node) do
          None -> println("2d context unavailable")
          Some(ctx) ->
            let saved = match Dom.store_get("perihelion.v1") do
              None -> ""
              Some(sv) -> sv
            end
            let (best, runs) = Perihelion.Core.decode_save(saved)
            Dom.on_frame(fn _ -> boot(ctx, node, best, runs))
        end
    end
  end

end
