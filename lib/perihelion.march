-- Perihelion — impure shell: input polling, Canvas rendering, the frame loop.
-- All game logic lives in Perihelion.Core (pure); star placement in Perihelion.Level.
-- The on_frame callback takes one ignored Int argument (`fn _ -> ...`) — see
-- stdlib/dom.march's module doc on deferred-callback signatures.
mod Perihelion do
  needs IO.Clock

  pfn two_pi() : Float do 6.283185307179586 end

  -- A fresh, unpredictable seed for a new universe at boot -- same idea as
  -- Tetris's lcg_seed, but simpler: Random.seed(n) accepts any Int magnitude
  -- (it only ever consumes n's low/high 32-bit words), so there's no need to
  -- clamp into a small positive range the way a hand-rolled LCG would.
  pfn boot_seed() : Int do
    float_to_int(unix_time(()) * 1000000.0)
  end

  -- ── Visual-effects state ─────────────────────────────────────────────
  -- Purely cosmetic, shell-local (not in the pure Game record, not tested):
  -- an elapsed-time accumulator driving the stars' pulsating glow, live
  -- particle instances (both one-off capture bursts and the continuous
  -- rocket-exhaust stream trailing the ship -- see spawn_thrust_particles),
  -- and an active capture-flash ring. Threaded through tick() the same way
  -- `game` is.
  type Particle = { x : Float, y : Float, vx : Float, vy : Float, life : Float, max_life : Float }

  -- A flying chunk-sprite piece (see spawn_chunk_debris), spawned when an
  -- asteroid dies -- same shape as Particle but with rotation/spin and a
  -- sprite index, since it draws an image rather than a plain dot.
  type Debris = { x : Float, y : Float, vx : Float, vy : Float, rot : Float, spin : Float, life : Float, max_life : Float, img_idx : Int }

  -- actx/muted ride along in the same shell-local record: sound is another
  -- purely-cosmetic side effect keyed off the same before/after Game diff
  -- the particle/flash system already computes.
  type Fx = {
    t : Float,
    particles : List(Particle),
    flash : Option((Float, Float, Float)),
    actx : Audio.Ctx,
    muted : Bool,
    gl : Option(WebGL.Context),
    player_sprite : Option(Node),
    shield_hull : List((Float, Float)),
    enemy_tops : List(Node),
    enemy_mids : List(Node),
    enemy_bots : List(Node),
    icon_portal : Option(Canvas.Image),
    icon_missile : Option(Canvas.Image),
    icon_railgun_stack : Option(Canvas.Image),
    icon_bomb : Option(Canvas.Image),
    icon_energy_shield : Option(Canvas.Image),
    icon_railgun : Option(Canvas.Image),
    icon_faster_fire : Option(Canvas.Image),
    icon_bullet_ward : Option(Canvas.Image),
    icon_deflector_plating : Option(Canvas.Image),
    icon_star_thrust : Option(Canvas.Image),
    icon_trajectory_preview : Option(Canvas.Image),
    -- Purely cosmetic view zoom, toggled by Z (see toggle_zoom_target):
    -- `zoom` is the current rendered scale, eased each frame toward
    -- `zoom_target` (1.0 or 2.0) the same way the camera eases its pan.
    zoom : Float,
    zoom_target : Float,
    -- asteroid_01..05.png, indexed by a per-asteroid roll of shape_seed (see
    -- asteroid_sprite_idx) -- an entry is None if that image failed to
    -- load, in which case that asteroid falls back to the procedural jagged
    -- polygon draw_asteroid_edges already draws (see draw_asteroids).
    asteroid_sprites : List(Option(Canvas.Image)),
    -- chunk_01..09.png, picked per debris piece when an asteroid dies (see
    -- spawn_chunk_debris) -- None entries fall back to a plain dot, same
    -- graceful-degradation shape as asteroid_sprites.
    chunk_sprites : List(Option(Canvas.Image)),
    debris : List(Debris),
    -- Death explosion + screen shake, both triggered together the frame
    -- Playing -> Over (see step_fx's `just_died` param -- step_fx can't
    -- detect that transition itself, since it only ever sees the
    -- post-update Game, so tick() computes it and passes it in explicitly).
    -- *_time_left counts down to 0 (inactive); world-space explosion_x/y is
    -- captured once at the moment of death and held steady while it plays.
    explosion_x : Float,
    explosion_y : Float,
    explosion_time_left : Float,
    shake_time_left : Float
  }

