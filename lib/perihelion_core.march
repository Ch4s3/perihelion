-- Perihelion.Core — pure game state + physics. No Dom/Canvas imports.
-- All tuning constants live in the block below; nothing else is magic.
-- World coords are y-down (canvas-native): climbing = decreasing y.
-- The rng field is a stdlib Random.Rng, seeded from an Int in new_game.
-- Random's sfc32 core is bit-identical on the interpreter, native, and
-- --target js backends, so a seeded run replays the same star ladder
-- everywhere (it replaced a hand-rolled 31-bit LCG once Random became
-- JS-portable; see specs/progress.md, sfc32 Random core).
mod Perihelion.Core do

  -- ── Tuning constants ─────────────────────────────────────────────────
  -- view_w/view_h are NOT constants — the game is full-screen, so the world's
  -- visible size is live on Game (view_w/view_h fields, refreshed from
  -- Dom.window_size() every tick). These two are only the boot-time default
  -- for new_game/callers with no real viewport yet.
  fn default_view_w() : Float do 400.0 end
  fn default_view_h() : Float do 640.0 end
  fn dt() : Float do 0.0166667 end
  fn orbit_speed() : Float do 1.8 end
  fn fly_speed() : Float do 340.0 end
  fn assist_strength() : Float do 1600.0 end
  fn assist_range_mult() : Float do 2.4 end
  fn cam_ease() : Float do 3.0 end
  fn cam_anchor() : Float do 0.6 end
  -- Horizontal dead zone: camera_x holds still until the focus point (ball
  -- while flying, current star while orbiting) would render outside
  -- [cam_dead_zone, 1 - cam_dead_zone] of the screen width, then eases just
  -- enough to bring it back to that edge -- not all the way to center.
  fn cam_dead_zone() : Float do 0.25 end
  fn kill_margin() : Float do 40.0 end
  fn overshoot_margin() : Float do 150.0 end
  -- How long a StarJump travel pause lasts (see JumpTransit) -- the ball is
  -- frozen/invulnerable/uncontrollable for this long before landing.
  fn jump_transit_duration() : Float do 0.4 end
  fn fall_margin() : Float do 200.0 end
  -- Ladder generation stays this many screen-heights ahead of the visible
  -- top edge (world y = camera_y), so a newly-generated star is always
  -- already off-screen before it scrolls into view -- no visual pop-in.
  fn lookahead_screens() : Float do 1.5 end
  fn two_pi() : Float do 6.283185307179586 end
  fn mult_cap() : Int do 5 end

  -- First guaranteed item spawn: rolled once per run (fresh_run) and
  -- consumed the one time stars_chained reaches it (on_capture, forward
  -- capture only). Weighted toward an earlier appearance so most runs see
  -- their first item well before the early/guaranteed milestone beats
  -- (star 5 / star 10 -- see Perihelion.Upgrades.early_milestone_star /
  -- milestone_star_interval). Independent of and in addition to normal
  -- per-kill drops (Perihelion.Combat.roll_drops) -- this always fires on
  -- schedule, even if the player already got lucky with an earlier kill.
  fn first_item_star_early() : Int do 3 end
  fn first_item_star_mid() : Int do 6 end
  fn first_item_star_late() : Int do 9 end
  fn first_item_star_early_chance() : Float do 0.5 end
  fn first_item_star_mid_chance() : Float do 0.25 end

  doc "Orbit direction, the same for every star: capturing a new star must never reverse the player's spin."
  fn orbit_dir(_i : Int) : Float do
    1.0
  end

  -- ── Types ────────────────────────────────────────────────────────────
  -- One orbit ring: a radius the ball can circle at, and the angular-speed
  -- multiplier while on it. A star carries a non-empty list of these ordered
  -- inner -> outer (index 0 = tightest, last = capture_radius = the boundary
  -- that triggers capture). Single-orbit stars just have one entry.
  type Orbit = { radius : Float, speed_mult : Float }

  -- speed_mult scales this star's orbit angular speed (see step_orbit) --
  -- some stars spin faster or slower than the base orbit_speed(). It is the
  -- OUTER ring's speed; inner rings (if any) carry their own in `orbits`.
  -- capture_radius stays the outermost ring's radius (the capture boundary),
  -- so ship/asteroid/find_capture logic keyed on it is unaffected.
  type Star = { x : Float, y : Float, radius : Float, capture_radius : Float, speed_mult : Float,
                orbits : List(Orbit) }

  -- Orbiting(star_idx, ring_idx, angle): ring_idx indexes into the star's
  -- `orbits` (0 = innermost). W/S step it out/in (see step_orbit).
  type BallMode = Orbiting(Int, Int, Float) | Flying(Float, Float)

  type Phase = Ready | Playing | Over | Milestone

  -- Why the current/last run ended -- DeathNone until end_run sets a real
  -- cause, so the shell can show a "hit an asteroid"-style line on the Over
  -- screen instead of just "score X". DeathMissed covers every check_death
  -- condition (fell off, overshot, ...); the others come from
  -- Combat.collide_ball_hazards_shield_or_die.
  type DeathCause = DeathNone | DeathMissed | DeathAsteroid | DeathEnemyShip | DeathEnemyShot

  type RunRecord = { score : Int, stars : Int, max_mult : Int }

  -- A StarJump special mid-travel: the ball is frozen at (start_x, start_y)
  -- (mode/position untouched in Game), invulnerable, and ignores input while
  -- this counts down. target_idx was rolled once at activation (see
  -- apply_star_jump); when time_left reaches 0, step_jump_transit lands the
  -- ball there via the same on_capture seam a normal forward capture uses.
  type JumpTransit = { target_idx : Int, start_x : Float, start_y : Float, time_left : Float }

  type Game = {
    -- The one master seed for this run: everything random -- the gameplay
    -- rng below, and (via Perihelion.Nebula/the shell's starfield hash) the
    -- nebula layout and background starfield -- derives from it, so a given
    -- seed reproduces the ENTIRE run. Set once at run start (fresh_run) and
    -- never mutated during play; a new run (boot/restart/reset) draws a
    -- fresh one.
    seed : Int,
    phase : Phase,
    ball_x : Float,
    ball_y : Float,
    mode : BallMode,
    stars : List(Star),
    current : Int,
    score : Int,
    best : Int,
    camera_y : Float,
    -- Horizontal camera offset. Unlike camera_y (which always follows the
    -- focus point), camera_x only pans when the focus drifts outside a
    -- dead zone -- see step_camera -- so most of the time it stays put
    -- (world x == screen x) rather than constantly re-centering.
    camera_x : Float,
    rng : Random.Rng,
    asteroids : List(Asteroid),
    ships : List(Ship),
    player_shots : List(Shot),
    enemy_shots : List(Shot),
    pickups : List(Pickup),
    shield : Int,
    multiplier : Int,
    max_mult : Int,
    -- Consecutive kills of each type without an intervening kill of the
    -- OTHER type (see Combat.collide_shots_ships/collide_shots_asteroids).
    -- Crossing a multiple of the kill-streak threshold bumps `multiplier`
    -- itself, capped at mult_cap() -- same field, same decay rules as the
    -- star-capture combo (a slow/backward star capture resets it to 1).
    ship_kill_streak : Int,
    asteroid_kill_streak : Int,
    owned_weapons : List(Perihelion.Upgrades.WeaponKind),
    active_weapon_idx : Int,
    fire_rate_stacks : Int,
    bullet_ward : Bool,
    deflector_plating : Bool,
    -- Once true (via DefenseShield's Upgrades pickup), every FUTURE shield
    -- pickup (Combat.collide_ball_pickups) grants 2 charges instead of 1.
    -- Distinct from DefenseShield's own immediate +1-charge grant.
    shield_reinforced : Bool,
    special : Option(Perihelion.Upgrades.SpecialKind),
    special_charges : Int,
    -- Which of the 3 targetable stars ahead (current+1..current+3) the
    -- star-killer weapon's reticle sits on: 0/1/2. Only meaningful while
    -- StarKiller is the active weapon, but always tracked (see Task 6 for
    -- why W/D update it unconditionally).
    starkiller_target_offset : Int,
    starkiller_cooldown : Float,
    -- The 3 choices offered by the currently-open milestone screen; Nil
    -- when phase isn't Milestone. Populated when a milestone triggers,
    -- cleared (back to Nil) when the player picks one and play resumes.
    milestone_choices : List(Perihelion.Upgrades.UpgradeKind),
    stars_chained : Int,
    -- Which forward-capture count (3, 6, or 9) triggers the guaranteed
    -- first item spawn -- see first_item_star_early/mid/late above and
    -- on_capture below. Rolled once in fresh_run.
    first_item_star : Int,
    loop_angle : Float,
    fire_cooldown : Float,
    director : Perihelion.Director.Director,
    runs : List(RunRecord),
    view_w : Float,
    view_h : Float,
    -- Transient one-frame signals, not persistent state -- Combat.collide /
    -- on_capture set these fresh every call (never accumulate across
    -- frames); the shell just reads them once per tick, same "read-once"
    -- shape as taps/key_presses. fx_bursts: world-space points where an
    -- asteroid died (shot or collision) THIS frame, for a particle burst.
    -- capture_flash: the star just captured (forward progress only), for a
    -- brief highlight pulse.
    fx_bursts : List((Float, Float)),
    capture_flash : Option((Float, Float)),
    -- Freezes step_playing entirely while true (see update) -- toggled by
    -- P (or the shell's on-screen button) only during Playing. Not its own
    -- Phase variant so every existing Phase match arm stays untouched.
    paused : Bool,
    -- Another read-once signal, same shape as fx_bursts/capture_flash: true
    -- for exactly the one frame the ball flew through a pickup (Combat's
    -- collide_ball_pickups), so the shell can play a collection sound.
    pickup_collected : Bool,
    -- Set once by end_run when the run ends; DeathNone the rest of the
    -- time (not read-once/reset-per-frame like the signals above, since
    -- the Over screen needs it to stay put for as long as it's shown).
    death_cause : DeathCause,
    -- Some while a StarJump special is mid-travel-pause; None otherwise.
    -- See JumpTransit and step_jump_transit.
    jump : Option(JumpTransit)
  }

  -- ── Helpers ──────────────────────────────────────────────────────────
  doc "The star at index `i` of the ladder, if it exists."
  fn star_at(game : Game, i : Int) : Option(Star) do
    List.nth_opt(game.stars, i)
  end

  -- No List.filter_indexed in stdlib -- List.take/List.drop compose to the
  -- same "everything except index i" result.
  pfn remove_at(xs : List(Star), idx : Int) : List(Star) do
    List.append(List.take(xs, idx), List.drop(xs, idx + 1))
  end

  doc "Remove the star at ladder index `idx` (star-killer's effect). Anything orbiting/targeting it is the CALLER's responsibility to clean up (Combat does this for ships, since Core doesn't know about Ship)."
  fn remove_star(game : Game, idx : Int) : Game do
    { game with stars: remove_at(game.stars, idx) }
  end

  doc "How many orbit rings star `s` has."
  fn ring_count(s : Star) : Int do
    List.length(s.orbits)
  end

  doc "Ring `i` of star `s` (0 = innermost). Falls back to a ring at the capture radius if `i` is somehow out of range."
  fn ring_at(s : Star, i : Int) : Orbit do
    match List.nth_opt(s.orbits, i) do
      Some(o) -> o
      None    -> { radius: s.capture_radius, speed_mult: s.speed_mult }
    end
  end

  doc "Index of the outermost ring (the capture boundary)."
  fn outer_ring(s : Star) : Int do
    ring_count(s) - 1
  end

  -- W steps outward (toward a wider ring / higher index), S steps inward,
  -- clamped to [0, n-1]. Edge-triggered: one keypress = one step. Both W and
  -- S pressed the same frame cancel out. Single-ring stars (n == 1) clamp to
  -- 0, so W/S are silently no-ops there.
  pfn adjust_ring(ring_idx : Int, keys : List(String), n : Int) : Int do
    let out = List.any(keys, fn k -> k == "w" || k == "W")
    let inn = List.any(keys, fn k -> k == "s" || k == "S")
    let delta = (if out do 1 else 0 end) - (if inn do 1 else 0 end)
    let target = ring_idx + delta
    if target < 0 do 0 else if target > n - 1 do n - 1 else target end end
  end

  doc "The player's currently-active weapon (index-clamped against owned_weapons, which only grows, never shrinks -- so no out-of-range risk in practice, but clamped defensively)."
  fn active_weapon(game : Game) : Perihelion.Upgrades.WeaponKind do
    let n = List.length(game.owned_weapons)
    let idx = if game.active_weapon_idx >= n do 0 else game.active_weapon_idx end
    match List.nth_opt(game.owned_weapons, idx) do
      Some(w) -> w
      None -> Perihelion.Upgrades.Base
    end
  end

  -- Edge-triggered like adjust_ring: one keypress this frame = one step.
  -- Q/E both pressed cancel out (net 0), same convention as W/S.
  pfn adjust_weapon(idx : Int, keys : List(String), n : Int) : Int do
    let next = List.any(keys, fn k -> k == "e" || k == "E")
    let prev = List.any(keys, fn k -> k == "q" || k == "Q")
    let delta = (if next do 1 else 0 end) - (if prev do 1 else 0 end)
    let raw = int_mod(idx + delta, n)
    if raw < 0 do raw + n else raw end
  end

  -- D advances the star-killer reticle (targets a farther star), W pulls it
  -- back in -- edge-triggered, same convention as adjust_ring/adjust_weapon.
  -- W does double duty here: it ALSO steps the orbit ring outward (see
  -- adjust_ring/step_orbit) -- the two effects are orthogonal (ring-stepping
  -- only matters while orbiting normally; retargeting only matters/is drawn
  -- when StarKiller is the active weapon), so both firing unconditionally is
  -- intentional, not a bug.
  pfn adjust_starkiller_target(offset : Int, keys : List(String)) : Int do
    let dn = List.any(keys, fn k -> k == "d" || k == "D")
    let up = List.any(keys, fn k -> k == "w" || k == "W")
    let delta = (if dn do 1 else 0 end) - (if up do 1 else 0 end)
    int_mod(offset + delta + 3, 3) -- +3 before mod to keep it non-negative for delta = -1
  end

  -- ── Special (X) ──────────────────────────────────────────────────────
  -- Fraction of the way StarThrust turns the ball's HEADING toward the
  -- nearest star, blending current-direction and toward-star unit vectors
  -- before renormalizing back to fly_speed() -- a fixed heading fraction
  -- (not a raw velocity add) so it reliably corrects course regardless of
  -- current speed/direction, instead of a small nudge that barely bends a
  -- fast-moving trajectory (see step_playing's StarThrust arm).
  fn star_thrust_blend() : Float do 0.55 end

  pfn dist2(ax : Float, ay : Float, bx : Float, by_ : Float) : Float do
    let dx = ax - bx
    let dy = ay - by_
    dx * dx + dy * dy
  end

  pfn nearest_star_dir_go(game : Game, stars : List(Star), best : Star, best_d2 : Float) : Option((Float, Float)) do
    match stars do
      Nil ->
        let dx = best.x - game.ball_x
        let dy = best.y - game.ball_y
        let d = Math.sqrt(best_d2)
        if d > 0.0 do Some((dx / d, dy / d)) else None end
      Cons(s, rest) ->
        let d2 = dist2(game.ball_x, game.ball_y, s.x, s.y)
        if d2 < best_d2 do nearest_star_dir_go(game, rest, s, d2) else nearest_star_dir_go(game, rest, best, best_d2) end
    end
  end

  -- Direction (unit vector) from the ball toward the single nearest star in
  -- the ladder, regardless of approach/assist-bubble membership -- unlike
  -- nearest_assist_target, star thrust always has *a* nearest star to nudge
  -- toward as long as any star exists.
  pfn nearest_star_dir(game : Game) : Option((Float, Float)) do
    match game.stars do
      Nil -> None
      Cons(s0, rest) -> nearest_star_dir_go(game, rest, s0, dist2(game.ball_x, game.ball_y, s0.x, s0.y))
    end
  end

  fn star_jump_max_stars() : Int do 4 end

  -- Draws 1..star_jump_max_stars() rungs ahead and starts a JumpTransit
  -- travel pause there -- the ball freezes at its current position
  -- (invulnerable, ignores input, see step_playing/collide_ball_*) until
  -- step_jump_transit lands it via on_capture, the same scoring seam a
  -- skilled forward capture uses (see on_capture's doc comment). A free
  -- jump therefore scores/bumps the multiplier/can trigger a milestone
  -- exactly like a normal capture, just delayed until landing instead of
  -- happening on this activation frame.
  pfn apply_star_jump(game : Game) : Game do
    let (rng2, t) = Perihelion.Level.draw_pub(game.rng)
    let roll = 1 + float_to_int(t * int_to_float(star_jump_max_stars()))
    let target_idx = game.current + roll
    match star_at(game, target_idx) do
      None -> { game with rng: rng2 } -- not enough ladder generated yet; consume the roll, no-op the jump (rare, harmless)
      Some(_) ->
        { game with rng: rng2, special_charges: game.special_charges - 1,
            jump: Some({ target_idx: target_idx, start_x: game.ball_x, start_y: game.ball_y,
                         time_left: jump_transit_duration() }) }
    end
  end

  -- Resolves a JumpTransit once its travel pause elapses, landing the ball
  -- via on_capture (same seam apply_star_jump used to call directly before
  -- the travel pause existed). No-ops (just clears jump) if the target star
  -- vanished in the meantime (e.g. star-killer removed it mid-transit) --
  -- same rare/harmless fallback apply_star_jump itself uses when the ladder
  -- isn't generated far enough yet.
  pfn step_jump_transit(game : Game, dt_s : Float) : Game do
    match game.jump do
      None -> game
      Some(jt) ->
        let time_left2 = jt.time_left - dt_s
        if time_left2 > 0.0 do
          { game with jump: Some({ jt with time_left: time_left2 }) }
        else
          let g2 = { game with jump: None }
          match star_at(g2, jt.target_idx) do
            None -> g2
            Some(target) -> on_capture(g2, target, jt.target_idx)
          end
        end
    end
  end

  -- X activates whichever special is equipped. TrajectoryPreview is passive
  -- (drawn continuously by Task 10, not triggered) so its arm is a no-op here.
  -- A no-op whenever a JumpTransit is already in progress -- can't retrigger
  -- (or trigger any other special) mid-travel-pause.
  pfn apply_special(game : Game, keys : List(String)) : Game do
    match game.jump do
      Some(_) -> game
      None ->
        let pressed = List.any(keys, fn k -> k == "x" || k == "X")
        if !pressed || game.special_charges <= 0 do
          game
        else
          match game.special do
            None -> game
            Some(StarThrust) ->
              match nearest_star_dir(game) do
                None -> game
                Some(pair) ->
                  let (dx, dy) = pair
                  match game.mode do
                    Flying(vx, vy) ->
                      let speed = Math.sqrt(vx * vx + vy * vy)
                      let (ux, uy) = if speed > 0.0 do (vx / speed, vy / speed) else (dx, dy) end
                      let blend = star_thrust_blend()
                      let (fvx, fvy) = renormalize(ux * (1.0 - blend) + dx * blend, uy * (1.0 - blend) + dy * blend)
                      { game with mode: Flying(fvx, fvy), special_charges: game.special_charges - 1 }
                    Orbiting(_, _, _) -> game
                  end
              end
            Some(StarJump) ->
              apply_star_jump(game)
            Some(TrajectoryPreview) ->
              game -- passive; X does nothing (Task 10 draws the preview line)
          end
        end
    end
  end

  -- ── Update ───────────────────────────────────────────────────────────
  doc "Whether `keys` contains the hard-reset key (r/R). Shared by `update` (which honors it from every phase it dispatches directly) and the shell's `tick` (which needs the same check to decide whether to route a Milestone-phase frame through `update`'s reset instead of `pick_milestone`)."
  fn wants_reset(keys : List(String)) : Bool do
    List.any(keys, fn k -> k == "r" || k == "R")
  end

  doc "Whether `keys` contains the pause-toggle key (p/P) -- also synthesized by the shell when the on-screen pause button is tapped, so this one check covers both input paths."
  fn wants_pause_toggle(keys : List(String)) : Bool do
    List.any(keys, fn k -> k == "p" || k == "P")
  end

  doc "The only state transition: advance `game` by `dt_s` seconds, consuming this frame's taps, key presses, live cursor position, and viewport size."
  fn update(game : Game, taps : List((Int, Int)), keys : List(String), cursor : (Int, Int), view_w : Float, view_h : Float, dt_s : Float) : Game do
    -- fx_bursts/capture_flash/pickup_collected are read-once signals: reset
    -- here so a frame with no new event never re-serves a stale one;
    -- Combat.collide / on_capture overwrite them later THIS SAME pipeline
    -- call if something actually happens.
    let g0 = { game with view_w: view_w, view_h: view_h, fx_bursts: Nil, capture_flash: None, pickup_collected: false }
    -- R hard-resets from ANY phase (including while paused): abandon the
    -- current run and return to a fresh "tap to start" board. Persisted
    -- best + run history are kept (a reset is not a finished run, so it
    -- neither records nor updates them).
    if wants_reset(keys) do
      reset(g0)
    else
      let tapped = !List.is_empty(taps)
      match g0.phase do
        Ready ->
          if tapped do { g0 with phase: Playing } else g0 end
        Over ->
          if tapped do restart(g0) else g0 end
        Playing ->
          -- Pause only applies to Playing -- toggled here (not folded into
          -- step_playing) so the freeze is a hard stop: nothing below this
          -- branch runs at all while paused, not even a no-op pass through
          -- physics/combat.
          let paused2 = if wants_pause_toggle(keys) do !g0.paused else g0.paused end
          if paused2 do
            { g0 with paused: true }
          else
            step_playing({ g0 with paused: false }, tapped, keys, cursor, dt_s)
          end
        Milestone ->
          if tapped do
            match List.nth_opt(g0.milestone_choices, 0) do
              None -> g0
              Some(choice) -> top_up({ (apply_upgrade(g0, choice)) with phase: Playing, milestone_choices: Nil })
            end
          else
            g0
          end
      end
    end
  end

  pfn step_playing(game : Game, tapped : Bool, keys : List(String), cursor : (Int, Int), dt_s : Float) : Game do
    -- While a JumpTransit is in progress the ball is frozen/uncontrollable
    -- (see JumpTransit's doc comment) -- skip mode-based movement (which is
    -- also how W/S ring-change and tap-to-release are gated, since those
    -- only ever happen inside step_orbit) entirely rather than stepping it.
    let g0 = match game.jump do
      Some(_) -> game
      None ->
        match game.mode do
          Orbiting(idx, ring, angle) -> step_orbit(game, idx, ring, angle, tapped, keys, dt_s)
          Flying(vx, vy)             -> step_flight(game, vx, vy, dt_s)
        end
    end
    let n = List.length(g0.owned_weapons)
    let g1a = { g0 with active_weapon_idx: adjust_weapon(g0.active_weapon_idx, keys, n) }
    let g1 = { g1a with starkiller_target_offset: adjust_starkiller_target(g1a.starkiller_target_offset, keys) }
    let g1x = apply_special(g1, keys)
    let g1y = step_jump_transit(g1x, dt_s)
    match g1y.phase do
      Playing ->
        let g2 = Perihelion.Combat.step(g1y, dt_s)
        let g3 = Perihelion.Combat.fire(g2, keys, cursor, dt_s)
        let g4 = Perihelion.Combat.collide(g3)
        match g4.phase do
          Playing -> top_up(step_camera(g4, dt_s))
          _ -> g4
        end
      _ -> g1y
    end
  end

  pfn step_orbit(game : Game, idx : Int, ring : Int, angle : Float, tapped : Bool, keys : List(String), dt_s : Float) : Game do
    match star_at(game, idx) do
      None -> game
      Some(s) ->
        if tapped do
          release(game, idx, angle)
        else
          -- W/S may hop to an adjacent ring (same angle, new radius/speed).
          let ring2 = adjust_ring(ring, keys, ring_count(s))
          let o = ring_at(s, ring2)
          let a2 = angle + orbit_dir(idx) * orbit_speed() * o.speed_mult * dt_s
          let r = o.radius
          { game with
              mode: Orbiting(idx, ring2, a2),
              loop_angle: game.loop_angle + orbit_speed() * o.speed_mult * dt_s,
              ball_x: s.x + Math.cos(a2) * r,
              ball_y: s.y + Math.sin(a2) * r }
        end
    end
  end

  -- Tangent release: position = center + r*(cos a, sin a), so the velocity
  -- direction is d/da of that = dir * (-sin a, cos a), scaled to fly_speed.
  pfn release(game : Game, idx : Int, angle : Float) : Game do
    let d = orbit_dir(idx)
    let vx = 0.0 - d * fly_speed() * Math.sin(angle)
    let vy = d * fly_speed() * Math.cos(angle)
    { game with mode: Flying(vx, vy) }
  end

  pfn renormalize(vx : Float, vy : Float) : (Float, Float) do
    let m = Math.sqrt(vx * vx + vy * vy)
    if m > 0.0 do
      let out = (vx / m * fly_speed(), vy / m * fly_speed())
      out
    else
      let out = (vx, vy)
      out
    end
  end

  -- Nearest star the ball is APPROACHING whose assist bubble contains it.
  -- (Receding stars excluded so the just-left star never drags the launch.)
  pfn nearest_assist_target(game : Game, vx : Float, vy : Float, stars : List(Star), best : Option(Star), best_d : Float) : Option(Star) do
    match stars do
      Nil -> best
      Cons(s, rest) ->
        let dx = s.x - game.ball_x
        let dy = s.y - game.ball_y
        let d = Math.sqrt(dx * dx + dy * dy)
        let approaching = vx * dx + vy * dy > 0.0
        if approaching && d < assist_range_mult() * s.capture_radius && d < best_d do
          nearest_assist_target(game, vx, vy, rest, Some(s), d)
        else
          nearest_assist_target(game, vx, vy, rest, best, best_d)
        end
    end
  end

  -- Capture assist: bend velocity toward the nearest approaching star whose
  -- assist bubble contains the ball; renormalize so assist never adds speed.
  pfn assisted_velocity(game : Game, vx : Float, vy : Float, dt_s : Float) : (Float, Float) do
    match nearest_assist_target(game, vx, vy, game.stars, None, 999999.0) do
      None ->
        let out = (vx, vy)
        out
      Some(t) ->
        let dx = t.x - game.ball_x
        let dy = t.y - game.ball_y
        let dist = Math.sqrt(dx * dx + dy * dy)
        if dist > 0.0 do
          renormalize(vx + dx / dist * assist_strength() * dt_s,
                      vy + dy / dist * assist_strength() * dt_s)
        else
          let out = (vx, vy)
          out
        end
    end
  end

  fn trajectory_preview_dt() : Float do 0.05 end
  fn trajectory_preview_steps() : Int do 24 end

  pfn predict_trajectory_go(game : Game, x : Float, y : Float, vx : Float, vy : Float, n : Int, acc : List((Float, Float))) : List((Float, Float)) do
    if n == 0 do
      List.reverse(acc)
    else
      let simmed = { game with ball_x: x, ball_y: y }
      let (vx2, vy2) = assisted_velocity(simmed, vx, vy, trajectory_preview_dt())
      let x2 = x + vx2 * trajectory_preview_dt()
      let y2 = y + vy2 * trajectory_preview_dt()
      predict_trajectory_go(game, x2, y2, vx2, vy2, n - 1, Cons((x2, y2), acc))
    end
  end

  doc "Predicted flight path (a list of world-space points) if the player released right now from ring `ring` of star `idx` at `angle` -- reuses the exact release()/assisted_velocity() physics a real flight uses, simulated forward without touching the real Game. Nil if `idx` isn't a valid star (shouldn't happen while actually orbiting it)."
  fn predict_trajectory(game : Game, idx : Int, ring : Int, angle : Float) : List((Float, Float)) do
    match star_at(game, idx) do
      None -> Nil
      Some(s) ->
        let o = ring_at(s, ring)
        let start_x = s.x + Math.cos(angle) * o.radius
        let start_y = s.y + Math.sin(angle) * o.radius
        match (release(game, idx, angle)).mode do
          Flying(vx0, vy0) -> predict_trajectory_go(game, start_x, start_y, vx0, vy0, trajectory_preview_steps(), Nil)
          Orbiting(_, _, _) -> Nil -- unreachable: release() always returns Flying
        end
    end
  end

  -- Any star's ring captures — provided the ball is APPROACHING it
  -- (velocity . (star - ball) > 0), EXCEPT the star just released from
  -- (index == current). A tangent release is perpendicular to its own
  -- star's radial, so `approaching` is ~0 at the release instant — but that
  -- guard only holds for that one frame: the capture-assist steering force
  -- (assist_strength 1600 vs fly_speed 340) can curve the ball back into
  -- the origin ring within a few frames, at which point it IS approaching
  -- again and gets recaptured — the ball never escapes and a tap "does
  -- nothing" (release fires, then instant re-grab). Excluding index==current
  -- enforces the intended "can't recapture the star you just left" robustly.
  -- Rescue captures of OLDER rings (index < current) and forward captures
  -- (index > current) are unaffected. Grace includes the ball's own radius
  -- so a visual ring-touch counts.
  pfn find_capture(game : Game, vx : Float, vy : Float, stars : List(Star), i : Int) : Option((Int, Star)) do
    match stars do
      Nil -> None
      Cons(s, rest) ->
        let dx = s.x - game.ball_x
        let dy = s.y - game.ball_y
        let grace = s.capture_radius + Perihelion.Combat.ball_radius()
        let approaching = vx * dx + vy * dy > 0.0
        if i != game.current && approaching && Math.sqrt(dx * dx + dy * dy) <= grace do
          Some((i, s))
        else
          find_capture(game, vx, vy, rest, i + 1)
        end
    end
  end

  pfn step_flight(game : Game, vx : Float, vy : Float, dt_s : Float) : Game do
    let (vx2, vy2) = assisted_velocity(game, vx, vy, dt_s)
    let g = { game with
                ball_x: game.ball_x + vx2 * dt_s,
                ball_y: game.ball_y + vy2 * dt_s,
                mode: Flying(vx2, vy2) }
    match find_capture(g, vx2, vy2, g.stars, 0) do
      None -> check_death(g)
      Some((idx, t)) -> on_capture(g, t, idx)
    end
  end

  -- THE scoring seam: every successful capture flows through here.
  -- Forward captures (a higher star) score and grow the ladder; backward
  -- captures (an older ring caught mid-fall) are a rescue: re-orbit, no
  -- score, multiplier resets.
  pfn on_capture(game : Game, captured : Star, idx : Int) : Game do
    let angle = Math.atan2(game.ball_y - captured.y, game.ball_x - captured.x)
    -- Land on the outermost ring (the capture boundary just crossed);
    -- capture_radius == that ring's radius, so the snap position is exact.
    -- The player descends to tighter rings with S.
    let snapped = { game with
        mode: Orbiting(idx, outer_ring(captured), angle),
        loop_angle: 0.0,
        ball_x: captured.x + Math.cos(angle) * captured.capture_radius,
        ball_y: captured.y + Math.sin(angle) * captured.capture_radius }
    if idx > game.current do
      let new_mult =
        if game.loop_angle < two_pi() do
          if game.multiplier + 1 > mult_cap() do mult_cap() else game.multiplier + 1 end
        else
          1
        end
      let new_chained = game.stars_chained + 1
      -- A slow capture resets the combo (new_mult == 1) -- kill streaks are
      -- part of the same combo, so they reset with it (same decay rule).
      let streaks_live = new_mult > 1
      let captured_game = { snapped with
          current: idx,
          score: game.score + new_mult,
          stars_chained: new_chained,
          multiplier: new_mult,
          max_mult: max2(game.max_mult, new_mult),
          ship_kill_streak: if streaks_live do game.ship_kill_streak else 0 end,
          asteroid_kill_streak: if streaks_live do game.asteroid_kill_streak else 0 end,
          capture_flash: Some((captured.x, captured.y)) }
      let (rng_after_check, triggered) = Perihelion.Upgrades.milestone_check(captured_game.rng, new_chained)
      if triggered do
        let (rng2, choices) = Perihelion.Upgrades.draw_choices(rng_after_check, captured_game.owned_weapons, captured_game.special)
        top_up({ captured_game with phase: Milestone, rng: rng2, milestone_choices: choices })
      else
        top_up({ captured_game with rng: rng_after_check })
      end
    else
      { snapped with current: idx, multiplier: 1, ship_kill_streak: 0, asteroid_kill_streak: 0 }
    end
  end

  doc "Like `update`, but for the Milestone phase specifically: resolves which choice (0/1/2) a tap landed on, already computed by the shell from screen geometry."
  fn pick_milestone(game : Game, choice_idx : Option(Int)) : Game do
    -- Same read-once reset as `update`'s first line: this runs on EVERY
    -- Milestone-phase tick (both while waiting and when resolving a tap), so
    -- without it capture_flash/fx_bursts from the triggering capture would
    -- stay `Some(...)`/non-empty for the whole time the overlay is up
    -- instead of just the one frame it was set on.
    let g0 = { game with fx_bursts: Nil, capture_flash: None, pickup_collected: false }
    match choice_idx do
      None -> g0
      Some(i) ->
        match List.nth_opt(g0.milestone_choices, i) do
          None -> g0
          Some(choice) -> top_up({ (apply_upgrade(g0, choice)) with phase: Playing, milestone_choices: Nil })
        end
    end
  end

  doc "Apply a single drawn/chosen upgrade to the game state. Shared by the milestone screen (Task 3) and auto-applying random drops (Task 9)."
  fn apply_upgrade(game : Game, u : Perihelion.Upgrades.UpgradeKind) : Game do
    match u do
      OffenseWeapon(k) ->
        if List.member(game.owned_weapons, k) do
          game -- already owned (shouldn't happen via draw_choices, but drops aren't filtered -- see Task 9)
        else
          { game with owned_weapons: List.append(game.owned_weapons, Cons(k, Nil)) }
        end
      OffenseFireRate ->
        { game with fire_rate_stacks: game.fire_rate_stacks + 1 }
      DefenseBulletWard ->
        { game with bullet_ward: true }
      DefenseDeflector ->
        { game with deflector_plating: true }
      DefenseShield ->
        { game with shield: game.shield + 1, shield_reinforced: true }
      SpecialItem(k) ->
        { game with special: Some(k), special_charges: special_starting_charges(k) }
    end
  end

  doc "Starting charge count for a freshly-equipped special. TrajectoryPreview is passive (0 = unused, not a real limit)."
  fn special_starting_charges(k : Perihelion.Upgrades.SpecialKind) : Int do
    match k do
      StarThrust -> 3
      StarJump -> 1
      TrajectoryPreview -> 0
    end
  end

  -- Keep the ladder generated lookahead_screens() screen-heights above the
  -- visible top edge -- distance-based rather than a fixed star count, so a
  -- tall full-screen viewport (which can see much further ahead than the
  -- original 640px design) never scrolls into a star that pops into
  -- existence right as it enters view. (Enemy-ship spawning is no longer tied
  -- to star generation -- it's owned by the pacing director, see
  -- Perihelion.Combat.step_director.) Called both defensively every frame
  -- (step_playing) and eagerly right after a capture (skip-a-rung captures can
  -- consume lookahead faster than the per-frame call alone would replace it).
  fn top_up(game : Game) : Game do
    let fallback = { x: game.view_w / 2.0, y: 520.0, radius: 18.0, capture_radius: 54.0, speed_mult: 1.0,
                     orbits: Cons({ radius: 54.0, speed_mult: 1.0 }, Nil) }
    let top = top_star(game.stars, fallback)
    if top.y > game.camera_y - game.view_h * lookahead_screens() do
      let (fresh, rng2) = Perihelion.Level.next_star(game.rng, top, game.view_w)
      let g2 = { game with
          stars: List.append(game.stars, Cons(fresh, Nil)),
          rng: rng2 }
      top_up(g2)
    else
      game
    end
  end

  pfn top_star(stars : List(Star), fallback : Star) : Star do
    match stars do
      Nil -> fallback
      Cons(s, Nil) -> s
      Cons(_, rest) -> top_star(rest, fallback)
    end
  end

  pfn max2(a : Int, b : Int) : Int do
    if a > b do a else b end
  end

  doc "End the current run: record it, update best, enter Over. The ONLY writer of run records. `cause` is shown on the Over screen (see the shell's death_cause_text)."
  fn end_run(game : Game, cause : DeathCause) : Game do
    let rec = { score: game.score, stars: game.stars_chained, max_mult: game.max_mult }
    { game with
        phase: Over,
        best: max2(game.best, game.score),
        runs: List.take(Cons(rec, game.runs), 10),
        death_cause: cause }
  end

  pfn check_death(game : Game) : Game do
    let below = game.ball_y > game.camera_y + game.view_h + kill_margin()
    let off_side = game.ball_x < 0.0 - kill_margin() || game.ball_x > game.view_w + kill_margin()
    -- Overshoot: sailed well past the target star with no capture — without
    -- this, an upward miss never triggers ANY end state (no gravity, no top
    -- kill) and the run dangles forever off-screen.
    let fallback = { x: game.view_w / 2.0, y: 520.0, radius: 18.0, capture_radius: 54.0, speed_mult: 1.0,
                     orbits: Cons({ radius: 54.0, speed_mult: 1.0 }, Nil) }
    let topmost = top_star(game.stars, fallback)
    let overshot = game.ball_y < topmost.y - overshoot_margin()
    -- Falling below the current star is equally unrecoverable (no gravity,
    -- nothing below) — and the flying camera CHASES the ball, so the
    -- viewport-bottom kill above can no longer fire on its own.
    let fallen = match star_at(game, 0) do
      None -> false
      Some(c) -> game.ball_y > c.y + fall_margin()
    end
    if below || off_side || overshot || fallen do end_run(game, DeathMissed) else game end
  end

  -- Camera: anchored to the current star while orbiting; chases the BALL
  -- while flying so the player can watch the shot (and its miss/capture).
  pfn step_camera(game : Game, dt_s : Float) : Game do
    let focus_x = match game.mode do
      Flying(vx, _) -> game.ball_x
      Orbiting(_, _, _) ->
        match star_at(game, game.current) do
          None -> game.camera_x + game.view_w / 2.0
          Some(s) -> s.x
        end
    end
    let target_y = match game.mode do
      Flying(_, _) -> game.ball_y - cam_anchor() * game.view_h
      Orbiting(_, _, _) ->
        match star_at(game, game.current) do
          None -> game.camera_y
          Some(s) -> s.y - cam_anchor() * game.view_h
        end
    end
    -- Dead-zone pan: only move camera_x when the focus point would land
    -- outside the [dead_zone, 1 - dead_zone] band of the screen, and then
    -- only far enough to put it back at that band's edge.
    let left_edge = game.view_w * cam_dead_zone()
    let right_edge = game.view_w * (1.0 - cam_dead_zone())
    let screen_x = focus_x - game.camera_x
    let target_x =
      if screen_x < left_edge do focus_x - left_edge
      else if screen_x > right_edge do focus_x - right_edge
      else game.camera_x end end
    { game with
        camera_y: game.camera_y + (target_y - game.camera_y) * cam_ease() * dt_s,
        camera_x: game.camera_x + (target_x - game.camera_x) * cam_ease() * dt_s }
  end

  -- Weighted 3-way draw for first_item_star: 50% -> 3, 25% -> 6, 25% -> 9.
  -- Same threshold-compare pattern as Combat/Upgrades' own drop rolls
  -- (roll_drops, milestone_check), but calls Level.draw_pub directly
  -- rather than Perihelion.Combat.draw/Perihelion.Upgrades.draw -- both of
  -- those are pfn (private to their own module) and can't be called
  -- qualified from here.
  pfn roll_first_item_star(rng : Random.Rng) : (Random.Rng, Int) do
    let (rng2, roll) = Perihelion.Level.draw_pub(rng)
    let star =
      if roll < first_item_star_early_chance() do
        first_item_star_early()
      else if roll < first_item_star_early_chance() + first_item_star_mid_chance() do
        first_item_star_mid()
      else
        first_item_star_late()
      end end
    (rng2, star)
  end

  -- `seed` is the ONE master seed for the whole run: it seeds the gameplay
  -- rng below (star ladder, asteroid/ship rolls, ...) AND is stored on
  -- Game.seed for the shell to mix into the nebula/starfield hashes -- so
  -- the entire run (ladder, hazards, nebula, background) is reproducible
  -- from `seed` alone, and a new seed gives an entirely different run.
  pfn fresh_run(seed : Int, best : Int, runs : List(RunRecord), view_w : Float, view_h : Float) : Game do
    let (stars, rng2) = Perihelion.Level.initial_stars(Random.seed(seed), view_w)
    let start_angle = Math.pi() / 2.0
    match stars do
      Nil ->
        -- unreachable: initial_stars always returns 3 stars
        let (rng3, first_item_star) = roll_first_item_star(rng2)
        { seed: seed, phase: Ready, ball_x: 0.0, ball_y: 0.0, mode: Orbiting(0, 0, start_angle),
          stars: Nil, current: 0, score: 0, best: best,
          camera_y: 0.0, camera_x: 0.0, rng: rng3,
          asteroids: Nil, ships: Nil, player_shots: Nil, enemy_shots: Nil, pickups: Nil,
          shield: 0, multiplier: 1, max_mult: 1, ship_kill_streak: 0, asteroid_kill_streak: 0,
          owned_weapons: Cons(Perihelion.Upgrades.Base, Nil),
          active_weapon_idx: 0,
          fire_rate_stacks: 0,
          bullet_ward: false,
          deflector_plating: false,
          shield_reinforced: false,
          special: None,
          special_charges: 0,
          starkiller_target_offset: 0,
          starkiller_cooldown: 0.0,
          milestone_choices: Nil,
          stars_chained: 0,
          first_item_star: first_item_star,
          loop_angle: 0.0, fire_cooldown: 0.0,
          director: Perihelion.Director.initial(), runs: runs,
          view_w: view_w, view_h: view_h,
          fx_bursts: Nil, capture_flash: None, paused: false, pickup_collected: false, death_cause: DeathNone,
          jump: None }
      Cons(s0, _) ->
        let (rng3, first_item_star) = roll_first_item_star(rng2)
        { seed: seed, phase: Ready,
          ball_x: s0.x + Math.cos(start_angle) * s0.capture_radius,
          ball_y: s0.y + Math.sin(start_angle) * s0.capture_radius,
          mode: Orbiting(0, 0, start_angle),
          stars: stars, current: 0, score: 0, best: best,
          camera_y: s0.y - cam_anchor() * view_h,
          camera_x: 0.0,
          rng: rng3,
          asteroids: Nil, ships: Nil, player_shots: Nil, enemy_shots: Nil, pickups: Nil,
          shield: 0, multiplier: 1, max_mult: 1, ship_kill_streak: 0, asteroid_kill_streak: 0,
          owned_weapons: Cons(Perihelion.Upgrades.Base, Nil),
          active_weapon_idx: 0,
          fire_rate_stacks: 0,
          bullet_ward: false,
          deflector_plating: false,
          shield_reinforced: false,
          special: None,
          special_charges: 0,
          starkiller_target_offset: 0,
          starkiller_cooldown: 0.0,
          milestone_choices: Nil,
          stars_chained: 0,
          first_item_star: first_item_star,
          loop_angle: 0.0, fire_cooldown: 0.0,
          director: Perihelion.Director.initial(), runs: runs,
          view_w: view_w, view_h: view_h,
          fx_bursts: Nil, capture_flash: None, paused: false, pickup_collected: false, death_cause: DeathNone,
          jump: None }
    end
  end

  doc "A fresh game from an integer seed, phase Ready (tap to start), using the default viewport size (the shell overrides this with the real window size on boot)."
  fn new_game(seed : Int) : Game do
    new_game_saved(seed, 0, Nil, default_view_w(), default_view_h())
  end

  doc "A fresh game seeded with persisted best + run history (from decode_save) and an initial viewport size."
  fn new_game_saved(seed : Int, best : Int, runs : List(RunRecord), view_w : Float, view_h : Float) : Game do
    fresh_run(seed, best, runs, view_w, view_h)
  end

  -- Draw the NEXT run's seed from the current run's rng (not reused as-is:
  -- the old seed already produced the run that just ended).
  pfn next_seed(game : Game) : Int do
    let (s, _) = Random.next_int(game.rng)
    s
  end

  doc "One upgrade held at death randomly carries over into the next run (deterministic if only one was held). Only fresh_run's default state resets; a hard R-reset (see `reset` below) does NOT carry anything over -- that's a deliberate full stop, not a death."
  pfn restart(game : Game) : Game do
    let g0 = fresh_run(next_seed(game), game.best, game.runs, game.view_w, game.view_h)
    let held = Perihelion.Upgrades.owned_upgrades(game.owned_weapons, game.fire_rate_stacks,
      game.bullet_ward, game.deflector_plating, game.shield_reinforced, game.special)
    let (rng2, carry) = Perihelion.Upgrades.pick_carryover(g0.rng, held)
    let g1 = match carry do
      None -> g0
      Some(u) -> apply_upgrade(g0, u)
    end
    { g1 with rng: rng2, phase: Playing }
  end

  -- Hard reset (R key): a fresh board back in Ready ("tap to start"), with a
  -- freshly-drawn seed (so each reset lays a different ladder/nebula) and
  -- preserving persisted best + run history. Unlike restart it does NOT
  -- jump straight to Playing -- a reset is a full stop, then you start again.
  pfn reset(game : Game) : Game do
    fresh_run(next_seed(game), game.best, game.runs, game.view_w, game.view_h)
  end

  -- ── Persistence codec ────────────────────────────────────────────────
  -- Format: "best|score:stars:maxmult;score:stars:maxmult;..." (runs newest
  -- first, <= 10). Any malformed input decodes to (0, Nil) — a boot must
  -- never crash on garbage storage.

  pfn encode_run(r : RunRecord) : String do
    int_to_string(r.score) ++ ":" ++ int_to_string(r.stars) ++ ":" ++ int_to_string(r.max_mult)
  end

  doc "Serialize best + run history for Dom.store_set."
  fn encode_save(best : Int, runs : List(RunRecord)) : String do
    int_to_string(best) ++ "|" ++ String.join(List.map(runs, fn r -> encode_run(r)), ";")
  end

  pfn decode_run(s : String) : Option(RunRecord) do
    match String.split(s, ":") do
      Cons(a, Cons(b, Cons(c, Nil))) ->
        match string_to_int(a) do
          None -> None
          Some(score) ->
            match string_to_int(b) do
              None -> None
              Some(stars) ->
                match string_to_int(c) do
                  None -> None
                  Some(mm) -> Some({ score: score, stars: stars, max_mult: mm })
                end
            end
        end
      _ -> None
    end
  end

  pfn decode_runs(parts : List(String), acc : List(RunRecord)) : Option(List(RunRecord)) do
    match parts do
      Nil -> Some(List.reverse(acc))
      Cons(p, rest) ->
        match decode_run(p) do
          None -> None
          Some(r) -> decode_runs(rest, Cons(r, acc))
        end
    end
  end

  doc "Parse a save string from Dom.store_get. Malformed input yields (0, Nil)."
  fn decode_save(s : String) : (Int, List(RunRecord)) do
    let zero = (0, Nil)
    match String.split(s, "|") do
      Cons(best_s, Cons(runs_s, Nil)) ->
        match string_to_int(best_s) do
          None -> zero
          Some(best) ->
            match runs_s do
              "" -> (best, Nil)
              _ ->
                match decode_runs(String.split(runs_s, ";"), Nil) do
                  None -> zero
                  Some(rs) -> (best, rs)
                end
            end
        end
      _ -> zero
    end
  end

end
